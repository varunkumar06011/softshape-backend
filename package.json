{
  "name": "softshape-backend",
  "version": "1.0.0",
  "description": "Softshape AI backend API",
  "main": "dist/index.js",
  "scripts": {
    "dev": "ts-node src/index.ts",
    "dev:watch": "nodemon --exec ts-node src/index.ts",
    "build": "prisma generate && tsc && shx cp -r src/assets dist/assets",
    "start": "node dist/index.js",
    "railway:start": "sh scripts/start.sh",
    "postinstall": "prisma generate",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:studio": "prisma studio",
    "seed:bar": "ts-node --compiler-options \"{\\\"module\\\":\\\"CommonJS\\\"}\" prisma/seedBar.ts",
    "restore:bar-images": "ts-node --compiler-options \"{\\\"module\\\":\\\"CommonJS\\\"}\" prisma/restoreBarMenuImages.ts"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "prisma": {
    "seed": "ts-node prisma/seed.ts"
  },
  "dependencies": {
    "@prisma/client": "^6.19.3",
    "bcryptjs": "^3.0.3",
    "cors": "^2.8.5",
    "dotenv": "^16.5.0",
    "express": "^5.1.0",
    "express-rate-limit": "^7.5.1",
    "jsonwebtoken": "^9.0.3",
    "prisma": "^6.19.3",
    "socket.io": "^4.8.3",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.9.3",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.18",
    "@types/express": "^5.0.2",
    "@types/express-rate-limit": "^5.1.3",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^22.19.19",
    "dotenv-cli": "^11.0.0",
    "shx": "^0.3.4",
    "ts-node": "^10.9.2"
  }
}
