{
  "name": "softshape-backend",
  "version": "1.0.0",
  "description": "Softshape AI backend API",
  "main": "dist/index.js",
  "scripts": {
    "dev": "ts-node src/index.ts",
    "dev:watch": "nodemon --exec ts-node src/index.ts",
    "build": "prisma generate && tsc && shx cp -r src/assets dist/assets",
    "test": "vitest run",
    "test:watch": "vitest",
    "start": "node dist/index.js",
    "railway:start": "sh scripts/start.sh",
    "postinstall": "prisma generate",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:studio": "prisma studio",
    "seed:bar": "ts-node --compiler-options \"{\\\"module\\\":\\\"CommonJS\\\"}\" dev-scripts/seedBar.ts",
    "restore:bar-images": "ts-node --compiler-options \"{\\\"module\\\":\\\"CommonJS\\\"}\" dev-scripts/restoreBarMenuImages.ts"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "prisma": {
    "seed": "ts-node dev-scripts/seed.ts"
  },
  "dependencies": {
    "@sentry/node": "^10.61.0",
    "@socket.io/redis-adapter": "^8.3.0",
    "bcryptjs": "^3.0.3",
    "cors": "^2.8.5",
    "dotenv": "^16.5.0",
    "express": "^5.1.0",
    "express-rate-limit": "^7.5.1",
    "helmet": "^8.2.0",
    "ioredis": "^5.11.1",
    "jsonwebtoken": "^9.0.3",
    "pino": "^10.3.1",
    "pino-http": "^11.0.0",
    "razorpay": "^2.9.6",
    "resend": "^6.14.0",
    "socket.io": "^4.8.3",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.9.3",
    "xlsx": "^0.18.5",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@prisma/client": "^5.22.0",
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.18",
    "@types/express": "^5.0.2",
    "@types/express-rate-limit": "^5.1.3",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^22.19.19",
    "@types/supertest": "^7.2.0",
    "dotenv-cli": "^11.0.0",
    "pino-pretty": "^13.1.3",
    "prisma": "^5.22.0",
    "shx": "^0.3.4",
    "supertest": "^7.0.0",
    "ts-node": "^10.9.2",
    "vitest": "^2.1.0"
  }
}
