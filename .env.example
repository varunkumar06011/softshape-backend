# Softshape Backend — Environment Variables
# Copy this file to .env and fill in the real values.
# Variables marked (required) will prevent the server from starting if missing.

# ── Core Server ─────────────────────────────────────────────────────────────
# Node environment
NODE_ENV=development

# Port the Express server listens on
PORT=3000

# (required) JWT secret used to sign and verify all auth tokens.
# Must be a strong, random string (at least 32 characters).
JWT_SECRET=change-me-to-a-strong-random-string

# (optional) Separate secret for print-agent setup/session tokens.
# If not set, falls back to JWT_SECRET. Set a separate secret for independent rotation.
AGENT_JWT_SECRET=

# (optional but recommended) Separate secret used to sign email/phone verification proofs.
# Must be different from JWT_SECRET. If not set, JWT_SECRET is used as a fallback.
VERIFICATION_SECRET=change-me-to-a-different-strong-random-string

# (required) Prisma database connection string.
# Example for local PostgreSQL:
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/softshape?schema=public

# (required) Direct database connection string for Prisma migrations.
# Same as DATABASE_URL for local dev; for PgBouncer/production use a non-pooled URL.
DIRECT_URL=postgresql://postgres:postgres@localhost:5432/softshape?schema=public

# Prisma connection pool tuning
# Production: increase to 50+ for multi-tenant rush-hour load.
# 30 was too low — health check SELECT 1 queued behind 30 active connections
# and timed out, causing false offline triggers on the cashier panel.
PRISMA_CONNECTION_LIMIT=50
PRISMA_POOL_TIMEOUT=30

# ── CORS ────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins for the API.
# Overrides/adds to the built-in production origin list.
CORS_ORIGIN=http://localhost:5173,http://localhost:3000
# ALTERNATIVE: ALLOWED_ORIGINS=http://localhost:5173

# Frontend URL used in password-reset and welcome emails
FRONTEND_URL=http://localhost:5173

# ── Redis (optional but recommended for production) ───────────────────────
# Redis URL for Socket.IO adapter scaling and OTP caching.
# If not set, OTP will not work (email verification fails silently).
REDIS_URL=

# Set to true to use Redis-backed rate limiting across multiple instances.
# Default (false) uses in-memory rate limiting to save Upstash request quota.
REDIS_RATE_LIMIT=false

# ── Email (Resend) ──────────────────────────────────────────────────────────
# (required for real email/OTP) Resend API key.
RESEND_API_KEY=

# ── Payment (Razorpay) ──────────────────────────────────────────────────────
# Leave all three blank to use the MOCK payment gateway during onboarding.
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=

# (optional) Skip payment verification during onboarding. Set to true only for dev/staging.
DEV_SKIP_PAYMENT=false

# ── Groq AI (optional, used for PDF menu parsing with vision) ──────────────
# Get your API key at https://console.groq.com/keys
# Leave blank to use text-only PDF parsing (no AI vision fallback)
GROQ_API_KEY=

# ── QZ Tray Signing ─────────────────────────────────────────────────────────
# Private key used to sign QZ Tray connection requests.
# Leave blank if the QZ Tray / PrintStation path is not used.
QZ_PRIVATE_KEY=

# ── Cloudinary (optional, used for menu image uploads) ──────────────────────
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
CLOUDINARY_UPLOAD_PRESET=

# ── Firebase Admin (optional, used for phone verification) ──────────────────
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=

# ── Sentry Error Tracking (optional) ────────────────────────────────────────
SENTRY_DSN=

# ── Superadmin (optional) ─────────────────────────────────────────────────
# Secret used to protect the /api/superadmin endpoints.
SUPERADMIN_SECRET=

# ── Desktop App Auto-Updater ────────────────────────────────────────────────
# Serves the Tauri updater manifest at /api/updates/:app/:target/:current_version
# for the print agent, admin desktop and cashier desktop apps.
#
# Latest published version (no leading "v"). Must match the GitHub Release tag
# minus the "v". Bump this on every desktop release or clients won't update.
DESKTOP_APP_LATEST_VERSION=6.0.0
# Base URL of the GitHub release download for the print agent repo.
# Final URL = {DESKTOP_APP_DOWNLOAD_URL}/v{version}/print-agent-windows-x86_64-setup.exe
DESKTOP_APP_DOWNLOAD_URL=https://github.com/varunkumar06011/softshape-print-agent/releases/download
# Tauri updater signature (contents of the .exe.sig from the release build).
# Per-app + per-platform vars take priority; copy from the CI build logs.
PRINT_AGENT_DESKTOP_APP_SIGNATURE_WINDOWS=
# ADMIN_DESKTOP_DESKTOP_APP_SIGNATURE_WINDOWS=
# CASHIER_DESKTOP_DESKTOP_APP_SIGNATURE_WINDOWS=

# ── Runtime Updater (Phase 5) ───────────────────────────────────────────────
# The Runtime Host polls the edge-server hourly, which calls
# /api/edge/runtime-update-check to compare its version against these values.
# If newer, the Host downloads, swaps, and restarts the Runtime binary.
# Leave unset to disable Runtime auto-updates.
# RUNTIME_LATEST_VERSION=22.9.0
# RUNTIME_DOWNLOAD_URL=https://github.com/varunkumar06011/softshape-print-agent/releases/download/v22.9.0/edge-server.exe

# ── Logging / Keep-Alive ────────────────────────────────────────────────────
# pino log level: trace, debug, info, warn, error, fatal
LOG_LEVEL=info

# Keep-alive self-ping interval in milliseconds.
# Set to 600000 (10 min) for Railway/Render to prevent cold starts during idle periods.
# Cold starts take 20-30s and cause false offline triggers on cashier panels.
KEEP_ALIVE_INTERVAL_MS=600000

# ── Print Bill Deduplication ──────────────────────────────────────────────────
# Time window in milliseconds to reject near-simultaneous duplicate print requests
# when Redis is unavailable (fail-open). Default: 5000 (5 seconds).
BILL_DEDUP_WINDOW_MS=5000

# ── Backups ──────────────────────────────────────────────────────────────────
# Optional: S3 bucket for offsite backup uploads (requires AWS CLI installed)
S3_BACKUP_BUCKET=
# S3 key prefix for backup files
S3_BACKUP_PREFIX=backups/
# Optional: Separate DB URL for backups (use a non-pooled connection)
# If not set, DATABASE_URL is used for pg_dump
DATABASE_BACKUP_URL=
# Retention policy (days/weeks/months)
BACKUP_RETENTION_DAILY=7
BACKUP_RETENTION_WEEKLY=4
BACKUP_RETENTION_MONTHLY=12
# Slack-compatible webhook URL for backup failure notifications
BACKUP_WEBHOOK_URL=

# ── OTA Web Bundle Updates ───────────────────────────────────────────────────
# Used by GET /api/ota/version to serve latest web bundle metadata to
# Capacitor Android apps. Desktop apps use Tauri's built-in updater.
# Leave unset to disable OTA (apps stay on their bundled assets).
OTA_BUNDLE_VERSION=
OTA_BUNDLE_URL=
OTA_BUNDLE_SHA256=
OTA_BUNDLE_MIN_APP_VERSION=
OTA_BUNDLE_RELEASE_NOTES=
