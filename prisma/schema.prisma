generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ---------------------------------------------------------------------------
// Restaurant — multi-tenancy root & receipt generation
// ---------------------------------------------------------------------------
model Restaurant {
  id        String   @id @default(cuid())
  name      String
  address   String?
  phone     String?
  email     String?
  gstin     String?
  logoUrl   String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ---------------------------------------------------------------------------
// Menu
// ---------------------------------------------------------------------------
model Category {
  id           String     @id @default(uuid())
  name         String
  sortOrder    Int        @default(0)
  isActive     Boolean    @default(true)
  restaurantId String
  items        MenuItem[]
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  @@index([restaurantId])
}

model MenuItem {
  id           String            @id @default(uuid())
  name         String
  description  String?
  imageUrl     String?
  basePrice    Float             @default(0)
  isVeg        Boolean           @default(true)
  isAvailable  Boolean           @default(true)
  isDeleted    Boolean           @default(false)
  deletedAt    DateTime?
  menuType     MenuType          @default(FOOD)
  sortOrder    Int               @default(0)
  categoryId   String
  category     Category          @relation(fields: [categoryId], references: [id])
  restaurantId String
  variants     MenuItemVariant[]
  addons       MenuItemAddon[]
  orderItems   OrderItem[]
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt

  @@index([categoryId])
  @@index([restaurantId])
  @@index([restaurantId, isAvailable, isDeleted])
}

model MenuItemVariant {
  id          String   @id @default(uuid())
  name        String
  price       Float
  isDefault   Boolean  @default(false)
  isAvailable Boolean  @default(true)
  menuItemId  String
  menuItem    MenuItem @relation(fields: [menuItemId], references: [id], onDelete: Cascade)

  @@index([menuItemId])
}

model MenuItemAddon {
  id          String   @id @default(uuid())
  name        String
  price       Float
  isAvailable Boolean  @default(true)
  menuItemId  String
  menuItem    MenuItem @relation(fields: [menuItemId], references: [id], onDelete: Cascade)

  @@index([menuItemId])
}

enum MenuType {
  FOOD
  LIQUOR
}

// ---------------------------------------------------------------------------
// Floor plan
// ---------------------------------------------------------------------------
model Section {
  id           String   @id @default(cuid())
  name         String
  restaurantId String
  tables       Table[]
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Table {
  id               String      @id @default(cuid())
  number           Int
  capacity         Int         @default(4)
  status           TableStatus @default(AVAILABLE)
  workflowStatus   String?
  captainId        String?
  guests           Int         @default(0)
  sessionStartedAt DateTime?
  currentBill      Float       @default(0)
  kotHistory       Json        @default("[]")
  sectionId        String
  section          Section     @relation(fields: [sectionId], references: [id])
  restaurantId     String
  orders           Order[]
  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt

  @@unique([restaurantId, sectionId, number])
  @@index([restaurantId, status])
}

enum TableStatus {
  AVAILABLE
  OCCUPIED
  BILLING_REQUESTED
  RESERVED
  CLEANING
}

// ---------------------------------------------------------------------------
// Orders
// ---------------------------------------------------------------------------
model Order {
  id                 String        @id @default(cuid())
  tableId            String
  table              Table         @relation(fields: [tableId], references: [id])
  restaurantId       String
  status             OrderStatus   @default(PENDING)
  items              OrderItem[]
  transactions       Transaction[]
  totalAmount        Float         @default(0)
  billingRequested   Boolean       @default(false)
  billingRequestedAt DateTime?
  isDeleted          Boolean       @default(false)
  deletedAt          DateTime?
  createdAt          DateTime      @default(now())
  updatedAt          DateTime      @updatedAt

  @@index([restaurantId, status])
  @@index([tableId, status])
  @@index([restaurantId, isDeleted])
}

enum OrderStatus {
  PENDING
  CONFIRMED
  PREPARING
  READY
  BILLING_REQUESTED
  PAID
  CANCELLED
}

model OrderItem {
  id         String   @id @default(cuid())
  orderId    String
  order      Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  menuItemId String
  menuItem   MenuItem @relation(fields: [menuItemId], references: [id])
  name       String
  price      Float
  quantity   Int
  notes      String?
  menuType   MenuType @default(FOOD)
  removedFromBill Boolean @default(false)
  removedBy       String?
  removedAt       DateTime?
  addedByCashier  Boolean  @default(false)

  @@index([orderId])
  @@index([menuItemId])
}

// ---------------------------------------------------------------------------
// Billing
// ---------------------------------------------------------------------------
model Transaction {
  id           String   @id @default(cuid())
  restaurantId String
  orderId      String?
  order        Order?   @relation(fields: [orderId], references: [id], onDelete: SetNull)
  tableNumber  Int?
  captainId    String?
  amount       Float
  method       String   // CASH | CARD | UPI | SPLIT
  itemCount    Int      @default(0)
  items        Json     @default("[]")
  txnNumber    Int      @default(0)   // daily sequential: 1, 2, 3…
  txnDate      String   @default("")  // YYYY-MM-DD in IST — for daily reset
  paidAt       DateTime @default(now())
  createdAt    DateTime @default(now())

  @@index([restaurantId])
  @@index([restaurantId, paidAt])
  @@index([restaurantId, txnDate])
  @@index([orderId])
}

// ---------------------------------------------------------------------------
// Daily counters — sequential KOT & transaction numbers, reset per day (IST)
// ---------------------------------------------------------------------------
model DailyCounter {
  id           String   @id @default(cuid())
  restaurantId String
  counterDate  String   // "YYYY-MM-DD" IST
  kotCount     Int      @default(0)
  txnCount     Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@unique([restaurantId, counterDate])
  @@index([restaurantId, counterDate])
}

// ---------------------------------------------------------------------------
// Captain Assignments — revenue targets and discount limits per captain
// ---------------------------------------------------------------------------
model CaptainAssignment {
  id             String   @id @default(cuid())
  restaurantId   String
  captainId      String
  revenueTarget  Float
  discountLimit  Float
  assignedAt     DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@unique([restaurantId, captainId])
  @@index([restaurantId])
  @@index([captainId])
}

// ---------------------------------------------------------------------------
// Captain Targets — simplified assignment model used by the new target service
// ---------------------------------------------------------------------------
model CaptainTarget {
  id             String   @id @default(cuid())
  restaurantId   String
  captainId      String
  revenueTarget  Float
  discountLimit  Float
  assignedAt     DateTime @default(now())

  @@unique([restaurantId, captainId])
}
