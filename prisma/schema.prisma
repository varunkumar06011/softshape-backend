generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Outlet {
  id             String   @id @default(cuid())
  name           String
  slug           String   @unique
  restaurantCode String   @unique
  restaurantType String?  // DINE_IN | BAR_LOUNGE | BAR_WITH_DINING | CAFE | CLOUD_KITCHEN
  outletCount    Int      @default(1)
  parentRestaurantId String? // @deprecated — use organizationId for outlet grouping
  parent         Outlet? @relation("OutletRelation", fields: [parentRestaurantId], references: [id], onDelete: SetNull)
  outlets        Outlet[] @relation("OutletRelation")
  address        String?
  phone          String?
  email          String?
  gstin          String?
  logoUrl        String?
  receiptHeader    String?
  receiptSubHeader String?
  themePrimary     String?
  themeSecondary   String?
  printerConfig    Json?
  barUnitMl        Int             @default(30)
  fullBottleMl     Int             @default(750)
  halfBottleMl     Int             @default(375)
  fssai            String?
  pricesIncludeGst Boolean         @default(false)
  gstCategory      String          @default("NON_AC") // NON_AC | AC | TAKEAWAY — drives bill format
  gstRate          Float?          // null = auto from category; set = owner override
  gstRegistered    Boolean         @default(true)  // if false, no GST shown on bills
  serviceChargePercent Int         @default(0)
  deliveryPlatforms String[]
  enabledModules   Json?
  sharedKitchenOutletId String?  // when set, kitchen inventory is scoped to this outlet instead of self
  planPriceSnapshot    Decimal?  @db.Decimal(10, 2)
  paymentReference      String?
  onboardingCompletedAt DateTime?
  isActive              Boolean        @default(true)
  createdAt             DateTime       @default(now())
  updatedAt             DateTime       @updatedAt
  venuesMigrated        Boolean        @default(false)
  organizationId        String
  organization          Organization   @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  outletAccess          OutletAccess[]
  sections              Section[]
  users                 User[]
  venues                Venue[]
  venuePrices           VenuePrice[]
  venueMenuItemAvailability VenueMenuItemAvailability[]

  @@index([parentRestaurantId])
  @@index([organizationId])
  @@index([sharedKitchenOutletId])
}

model Organization {
  id             String    @id @default(cuid())
  name           String
  plan           String    @default("starter")
  subscriptionId String?
  billingStatus  String    @default("trialing")
  trialEndsAt    DateTime?
  paymentStatus  String    @default("LEGACY_EXEMPT")
  features       Json?
  enabledModules Json?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  outlets        Outlet[]
}

model OnboardingPayment {
  id               String   @id @default(cuid())
  sessionId        String
  restaurantId     String?
  plan             String
  numberOfOutlets  Int
  amount           Decimal  @db.Decimal(10, 2)
  currency         String   @default("INR")
  gateway          String   @default("MOCK")
  status           String   @default("CREATED")
  gatewayOrderId   String?
  gatewayPaymentId String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@index([sessionId])
  @@index([restaurantId])
}

model User {
  id               String                  @id @default(cuid())
  name             String
  email            String?                 @unique
  passwordHash     String?
  pin              String?
  isActive         Boolean                 @default(true)
  resetToken       String?
  resetTokenAt     DateTime?
  createdAt        DateTime                @default(now())
  updatedAt        DateTime                @updatedAt
  venueId          String?
  permissions      Json?                   @default("{}")
  role             UserRole
  outletId         String
  employee         Employee?
  outletAccess     OutletAccess[]
  advanceHistory   PayrollAdvanceHistory[] @relation("PayrollAdvanceHistoryCreator")
  outlet           Outlet                  @relation(fields: [outletId], references: [id])
  approvedExpenditures Expenditure[]       @relation("ExpenditureApprover")
  createdExpenditures  Expenditure[]       @relation("ExpenditureCreator")

  @@unique([outletId, email])
  @@index([outletId])
  @@index([email])
}

model OutletAccess {
  id          String   @id @default(cuid())
  userId      String
  outletId    String
  role        UserRole
  permissions Json?    @default("{}")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  outlet      Outlet   @relation(fields: [outletId], references: [id], onDelete: Cascade)
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, outletId])
  @@index([userId])
  @@index([outletId])
}

model Category {
  id            String     @id @default(uuid())
  name          String
  sortOrder     Int        @default(0)
  isActive      Boolean    @default(true)
  restaurantId  String
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt
  printerTarget String?
  items         MenuItem[]

  @@index([restaurantId])
  @@index([restaurantId, isActive, sortOrder])
}

model MenuItem {
  id                  String                      @id @default(uuid())
  name                String
  description         String?
  imageUrl            String?
  isVeg               Boolean                     @default(true)
  isAvailable         Boolean                     @default(true)
  sortOrder           Int                         @default(0)
  categoryId          String
  restaurantId        String
  createdAt           DateTime                    @default(now())
  updatedAt           DateTime                    @updatedAt
  basePrice           Decimal                     @default(0) @db.Decimal(10, 2)
  unit                String?                     @db.VarChar(20)
  isDeleted           Boolean                     @default(false)
  deletedAt           DateTime?
  printerTarget       String?
  printerName         String?
  menuType            MenuType                    @default(FOOD)
  gstEnabled          Boolean                     @default(true)
  isSpecial           Boolean                     @default(false)
  specialChannel      String?                     @default("BOTH")
  specialActive       Boolean                     @default(true)
  specialExpiresAt    DateTime?
  category            Category                    @relation(fields: [categoryId], references: [id])
  addons              MenuItemAddon[]
  recipes             MenuItemRecipe[]
  variants            MenuItemVariant[]
  orderItems          OrderItem[]
  priceProfileItems   PriceProfileItem[]
  venueAvailabilities VenueMenuItemAvailability[]
  venuePrices         VenuePrice[]
  inventoryItem       InventoryItem?

  @@index([categoryId])
  @@index([restaurantId])
  @@index([restaurantId, isAvailable, isDeleted])
}

model MenuItemVariant {
  id           String   @id @default(uuid())
  name         String
  price        Decimal  @db.Decimal(10, 2)
  isDefault    Boolean  @default(false)
  menuItemId   String
  isAvailable  Boolean  @default(true)
  restaurantId String
  menuItem     MenuItem @relation(fields: [menuItemId], references: [id], onDelete: Cascade)

  @@index([menuItemId])
  @@index([restaurantId])
}

model MenuItemAddon {
  id           String   @id @default(uuid())
  name         String
  price        Decimal  @db.Decimal(10, 2)
  isAvailable  Boolean  @default(true)
  menuItemId   String
  restaurantId String
  menuItem     MenuItem @relation(fields: [menuItemId], references: [id], onDelete: Cascade)

  @@index([menuItemId])
  @@index([restaurantId])
}

model Section {
  id           String        @id @default(cuid())
  name         String
  restaurantId String
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  floorId      String?
  sortOrder    Int           @default(0)
  venueId      String?
  floor        Floor?        @relation(fields: [floorId], references: [id])
  outlet       Outlet        @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  venue        Venue?        @relation(fields: [venueId], references: [id])
  tables       Table[]
  transactions Transaction[]

  @@index([restaurantId])
  @@index([venueId])
  @@index([floorId])
}

model Table {
  id               String      @id @default(cuid())
  number           Int
  capacity         Int         @default(4)
  status           TableStatus @default(AVAILABLE)
  sectionId        String
  restaurantId     String
  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt
  workflowStatus   String?
  captainId        String?
  guests           Int         @default(0)
  sessionStartedAt DateTime?
  currentBill      Decimal     @default(0) @db.Decimal(10, 2)
  kotHistory       Json        @default("[]")
  discount         Decimal?    @db.Decimal(5, 2)
  sectionTag       String?
  lastWaiterCallAt DateTime?
  orders           Order[]
  kots             Kot[]
  section          Section     @relation(fields: [sectionId], references: [id])

  @@unique([restaurantId, sectionId, number])
  @@index([restaurantId, status])
}

model TaxProfile {
  id                   String   @id @default(cuid())
  restaurantId         String
  name                 String
  gstCategory          String   @default("NON_AC")
  gstRate              Float?
  gstRegistered        Boolean  @default(true)
  serviceChargePercent Int      @default(0)
  isDefault            Boolean  @default(false)
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
  venues               Venue[]

  @@index([restaurantId])
}

model PriceProfile {
  id           String             @id @default(cuid())
  restaurantId String
  name         String
  isDefault    Boolean            @default(false)
  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt
  items        PriceProfileItem[]
  venues       Venue[]

  @@index([restaurantId])
}

model PriceProfileItem {
  id             String       @id @default(cuid())
  priceProfileId String
  menuItemId     String
  price          Decimal      @db.Decimal(10, 2)
  restaurantId   String
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  menuItem       MenuItem     @relation(fields: [menuItemId], references: [id], onDelete: Cascade)
  priceProfile   PriceProfile @relation(fields: [priceProfileId], references: [id], onDelete: Cascade)

  @@unique([priceProfileId, menuItemId])
  @@index([priceProfileId])
  @@index([menuItemId])
  @@index([restaurantId])
}

model Venue {
  id              String        @id @default(cuid())
  restaurantId    String
  name            String
  venueType       String        @default("DINE_IN")
  sortOrder       Int           @default(0)
  isActive        Boolean       @default(true)
  isDeleted       Boolean       @default(false)
  priceProfileId  String?
  taxProfileId    String?
  kotPrinterName  String?
  billPrinterName String?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  kotEnabled      Boolean       @default(true)
  floors          Floor[]
  sections        Section[]
  priceProfile    PriceProfile? @relation(fields: [priceProfileId], references: [id])
  restaurant      Outlet        @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  taxProfile      TaxProfile?   @relation(fields: [taxProfileId], references: [id])

  @@index([restaurantId])
}

model Floor {
  id           String    @id @default(cuid())
  venueId      String
  restaurantId String
  name         String
  sortOrder    Int       @default(0)
  isActive     Boolean   @default(true)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  venue        Venue     @relation(fields: [venueId], references: [id], onDelete: Cascade)
  sections     Section[]

  @@index([venueId])
  @@index([restaurantId])
}

model Order {
  id                 String       @id @default(cuid())
  tableId            String
  restaurantId       String
  status             OrderStatus  @default(PENDING)
  totalAmount        Decimal      @default(0) @db.Decimal(10, 2)
  billingRequested   Boolean      @default(false)
  billingRequestedAt DateTime?
  createdAt          DateTime     @default(now())
  updatedAt          DateTime     @updatedAt
  isDeleted          Boolean      @default(false)
  deletedAt          DateTime?
  billNumber         String?
  paidAt             DateTime?
  lastRequestId      String?
  inventoryDeducted  Boolean            @default(false)
  captainId          String?
  platform           String?            @default("DINE_IN")
  createdByUserId    String?
  table              Table              @relation(fields: [tableId], references: [id])
  items              OrderItem[]
  kots               Kot[]
  transactions       Transaction?
  deductionLogs      OrderDeductionLog[]

  @@index([restaurantId, status])
  @@index([tableId, status])
  @@index([restaurantId, isDeleted])
  @@index([restaurantId, status, paidAt(sort: Desc)])
  @@index([createdByUserId])
}

model OrderDeductionLog {
  id            String               @id @default(cuid())
  orderId       String
  restaurantId  String
  ingredientId  String
  menuItemId    String?
  quantity      Decimal              @db.Decimal(10, 2)
  status        String               // SUCCESS | FAILED | SKIPPED
  error         String?
  createdAt     DateTime             @default(now())
  updatedAt     DateTime             @default(now()) @updatedAt
  order         Order                @relation(fields: [orderId], references: [id], onDelete: Cascade)
  ingredient    KitchenInventoryItem @relation(fields: [ingredientId], references: [id], onDelete: Cascade)

  @@unique([orderId, ingredientId])
  @@index([orderId])
  @@index([restaurantId])
  @@index([restaurantId, status])
}

model OrderItem {
  id                String    @id @default(cuid())
  orderId           String
  menuItemId        String
  name              String
  price             Decimal   @db.Decimal(10, 2)
  quantity          Int
  notes             String?
  addedByCashier    Boolean   @default(false)
  originalQuantity  Int?
  cancelledQuantity Int       @default(0)
  editedQuantity    Int       @default(0)
  removedFromBill   Boolean   @default(false)
  removedBy         String?
  removedAt         DateTime?
  menuType          MenuType  @default(FOOD)
  menuItem          MenuItem  @relation(fields: [menuItemId], references: [id])
  order             Order     @relation(fields: [orderId], references: [id], onDelete: Cascade)
  kotItems          KotItem[]

  @@index([orderId])
  @@index([menuItemId])
  @@index([orderId, removedFromBill])
}

model Kot {
  id           String    @id @default(cuid())
  restaurantId String
  tableId      String
  orderId      String
  kotNumber    Int
  createdAt    DateTime  @default(now())
  table        Table     @relation(fields: [tableId], references: [id], onDelete: Cascade)
  order        Order     @relation(fields: [orderId], references: [id], onDelete: Cascade)
  items        KotItem[]

  @@unique([restaurantId, kotNumber])
  @@index([restaurantId, tableId])
  @@index([restaurantId, orderId])
  @@index([tableId])
  @@index([orderId])
}

model KotItem {
  id           String    @id @default(cuid())
  kotId        String
  orderItemId  String
  menuItemId   String
  name         String
  quantity     Int
  price        Decimal   @db.Decimal(10, 2)
  notes        String?
  status       String    @default("SENT")
  createdAt    DateTime  @default(now())
  kot          Kot       @relation(fields: [kotId], references: [id], onDelete: Cascade)
  orderItem    OrderItem @relation(fields: [orderItemId], references: [id], onDelete: Cascade)

  @@index([kotId])
  @@index([orderItemId])
  @@index([menuItemId])
}

model Transaction {
  id              String            @id @default(cuid())
  restaurantId    String
  orderId         String?           @unique
  tableNumber     Int?
  captainId       String?
  amount          Decimal           @db.Decimal(10, 2)
  method          String
  status          TransactionStatus @default(COMPLETED)
  itemCount       Int               @default(0)
  items           Json              @default("[]")
  sectionTag      String?
  txnNumber       Int               @default(0)
  txnDate         String            @default("")
  paidAt          DateTime          @default(now())
  createdAt       DateTime          @default(now())
  confirmedAt     DateTime?
  cancelledAt     DateTime?
  failedAt        DateTime?
  recoverySource  String?
  subtotal        Decimal?          @db.Decimal(10, 2)
  discountPercent Decimal?          @db.Decimal(5, 2)
  discountAmount  Decimal?          @db.Decimal(10, 2)
  cgst            Decimal?          @db.Decimal(10, 2)
  sgst            Decimal?          @db.Decimal(10, 2)
  grandTotal      Decimal?          @db.Decimal(10, 2)
  roundOff        Decimal?          @db.Decimal(10, 2)
  tipAmount       Decimal?          @db.Decimal(10, 2) @default(0)
  billNumber      String?
  tableLabel      String?
  sectionId       String?
  platform        String?
  createdByUserId String?
  order           Order?            @relation(fields: [orderId], references: [id])
  section         Section?          @relation(fields: [sectionId], references: [id])

  @@index([restaurantId])
  @@index([restaurantId, paidAt(sort: Desc)])
  @@index([restaurantId, txnDate])
  @@index([restaurantId, sectionId])
  @@index([createdByUserId])
  @@index([status])
  @@index([restaurantId, status, txnDate])
}

model DailyCounter {
  id           String   @id @default(cuid())
  restaurantId String
  counterDate  String
  kotCount     Int      @default(0)
  billCount    Int      @default(0)
  txnCount     Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  expenditureCount Int    @default(0) @map("voucherCount")

  @@unique([restaurantId, counterDate])
  @@index([restaurantId, counterDate])
}

model ProcessedRequest {
  id           String   @id @default(cuid())
  requestId    String
  actionType   String
  orderId      String?
  restaurantId String
  result       Json?
  createdAt    DateTime @default(now())
  deviceId     String?

  @@unique([requestId, actionType, restaurantId])
  @@index([restaurantId, createdAt])
  @@index([deviceId, restaurantId])
}

model CaptainAssignment {
  id            String   @id @default(cuid())
  restaurantId  String
  captainId     String
  revenueTarget Decimal  @db.Decimal(10, 2)
  discountLimit Decimal  @db.Decimal(10, 2)
  assignedAt    DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@unique([restaurantId, captainId])
  @@index([restaurantId])
  @@index([captainId])
}

model InventoryItem {
  id             String                   @id @default(cuid())
  menuItemId     String                   @unique
  restaurantId   String
  unitOfMeasure  String
  bottleSize     Int
  openingStock   Decimal                  @db.Decimal(10, 2)
  currentStock   Decimal                  @db.Decimal(10, 2)
  reorderLevel   Decimal                  @db.Decimal(10, 2)
  costPerBottle  Decimal?                 @db.Decimal(10, 2)
  lastRestocked  DateTime?
  createdAt      DateTime                 @default(now())
  updatedAt      DateTime                 @updatedAt
  dailySnapshots DailyInventorySnapshot[]
  menuItem       MenuItem                 @relation(fields: [menuItemId], references: [id], onDelete: Cascade)
  transactions   InventoryTransaction[]

  @@index([restaurantId])
  @@index([menuItemId])
  @@index([currentStock])
  @@map("inventory_items")
}

model InventoryTransaction {
  id              String        @id @default(cuid())
  restaurantId    String
  itemId          String
  orderId         String?
  type            String
  quantityChange  Decimal       @db.Decimal(10, 2)
  stockBefore     Decimal       @db.Decimal(10, 2)
  stockAfter      Decimal       @db.Decimal(10, 2)
  notes           String?
  createdBy       String?
  transactionDate DateTime      @default(now())
  item            InventoryItem @relation(fields: [itemId], references: [id], onDelete: Cascade)

  @@index([restaurantId, transactionDate])
  @@index([itemId])
  @@index([orderId])
  @@index([type])
  @@map("inventory_transactions")
}

model DailyInventorySnapshot {
  id           String        @id @default(cuid())
  restaurantId String
  snapshotDate String
  itemId       String
  itemName     String
  openingStock Decimal       @db.Decimal(10, 2)
  purchased    Decimal       @db.Decimal(10, 2)
  sold         Decimal       @db.Decimal(10, 2)
  wastage      Decimal       @db.Decimal(10, 2)
  adjusted     Decimal       @db.Decimal(10, 2)
  closingStock Decimal       @db.Decimal(10, 2)
  createdAt    DateTime      @default(now())
  item         InventoryItem @relation(fields: [itemId], references: [id], onDelete: Cascade)

  @@unique([restaurantId, snapshotDate, itemId])
  @@index([restaurantId, snapshotDate])
  @@map("daily_inventory_snapshots")
}

model VenuePrice {
  id           String   @id @default(cuid())
  venueId      String
  menuItemId   String
  price        Decimal  @db.Decimal(10, 2)
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  restaurantId String
  menuItem     MenuItem @relation(fields: [menuItemId], references: [id], onDelete: Cascade)
  restaurant   Outlet   @relation(fields: [restaurantId], references: [id], onDelete: Cascade)

  @@unique([venueId, menuItemId])
  @@index([venueId])
  @@index([menuItemId])
  @@index([restaurantId])
}

model VenueMenuItemAvailability {
  id           String   @id @default(cuid())
  venueId      String
  menuItemId   String
  restaurantId String
  isAvailable  Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  menuItem     MenuItem @relation(fields: [menuItemId], references: [id], onDelete: Cascade)
  restaurant   Outlet   @relation(fields: [restaurantId], references: [id], onDelete: Cascade)

  @@unique([venueId, menuItemId])
  @@index([venueId])
  @@index([menuItemId])
  @@index([restaurantId])
}

model PrintQueue {
  id           String    @id @default(cuid())
  restaurantId String
  eventId      String    @unique
  payload      Json
  status       String    @default("PENDING")
  createdAt    DateTime  @default(now())
  printedAt    DateTime?

  @@index([restaurantId, status])
  @@index([createdAt])
}

model Employee {
  id             String                  @id @default(cuid())
  restaurantId   String
  name           String
  age            Int?
  role           String?
  designation    String?
  workerCategory String?
  baseSalary     Decimal                 @db.Decimal(10, 2)
  joinDate       DateTime                @default(now())
  isActive       Boolean                 @default(true)
  createdVia     String?                 @default("ADMIN")
  createdAt      DateTime                @default(now())
  updatedAt      DateTime                @updatedAt
  idempotencyKey String?
  userId         String?                 @unique
  staffCode      String?
  attendance     Attendance[]
  user           User?                   @relation(fields: [userId], references: [id])
  advanceHistory PayrollAdvanceHistory[] @relation("PayrollAdvanceHistoryEmployee")
  payrolls       PayrollRecord[]         @relation("PayrollEmployee")
  expenditures   Expenditure[]           @relation("ExpenditureEmployee")

  @@unique([restaurantId, staffCode])
  @@index([restaurantId])
  @@index([idempotencyKey, restaurantId])
  @@index([userId])
}

model PayrollRecord {
  id                  String                  @id @default(cuid())
  restaurantId        String
  employeeId          String
  monthYear           String
  baseSalary          Decimal                 @db.Decimal(10, 2)
  absentDays          Int                     @default(0)
  advanceAmount       Decimal                 @default(0) @db.Decimal(10, 2)
  otDays              Int                     @default(0)
  otAmount            Decimal                 @default(0) @db.Decimal(10, 2)
  netPayable          Decimal                 @db.Decimal(10, 2)
  paidAmount          Decimal                 @default(0) @db.Decimal(10, 2)
  status              String                  @default("PENDING")
  notes               String?
  createdAt           DateTime                @default(now())
  updatedAt           DateTime                @updatedAt
  manualAdvanceAmount Decimal                 @default(0) @db.Decimal(10, 2)
  periodEnd           String?
  periodStart         String?
  presentDays         Float                   @default(0)
  advanceHistory      PayrollAdvanceHistory[] @relation("PayrollAdvanceHistoryRecord")
  employee            Employee                @relation("PayrollEmployee", fields: [employeeId], references: [id], onDelete: Cascade)
  expenditures        Expenditure[]           @relation("ExpenditurePayrollRecord")

  @@unique([employeeId, monthYear])
  @@index([restaurantId, monthYear])
}

model PayrollAdvanceHistory {
  id              String         @id @default(cuid())
  restaurantId    String
  employeeId      String
  payrollRecordId String?
  amount          Decimal        @db.Decimal(10, 2)
  reason          String?
  date            String
  createdById     String
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  createdBy       User           @relation("PayrollAdvanceHistoryCreator", fields: [createdById], references: [id])
  employee        Employee       @relation("PayrollAdvanceHistoryEmployee", fields: [employeeId], references: [id], onDelete: Cascade)
  payrollRecord   PayrollRecord? @relation("PayrollAdvanceHistoryRecord", fields: [payrollRecordId], references: [id])

  @@index([restaurantId])
  @@index([employeeId])
  @@index([payrollRecordId])
  @@index([createdById])
}

model Attendance {
  id           String    @id @default(cuid())
  restaurantId String
  employeeId   String
  date         String
  status       String
  checkInTime  DateTime?
  checkOutTime DateTime?
  notes        String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  employee     Employee  @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@unique([employeeId, date])
  @@index([restaurantId, date])
  @@index([employeeId])
}

model KitchenInventoryItem {
  id           String                @id @default(cuid())
  restaurantId String
  name         String
  unit         String
  category     String?
