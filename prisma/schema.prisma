generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Outlet {
  id             String   @id @default(cuid())
  name           String
  slug           String   @unique
  restaurantCode String   @unique
  restaurantType String?  // DINE_IN | BAR_LOUNGE | BAR_WITH_DINING | CAFE | CLOUD_KITCHEN
  outletCount    Int      @default(1)
  parentRestaurantId String? // @deprecated — use organizationId for outlet grouping
  parent         Outlet? @relation("OutletRelation", fields: [parentRestaurantId], references: [id], onDelete: SetNull)
  outlets        Outlet[] @relation("OutletRelation")
  address        String?
  phone          String?
  email          String?
  gstin          String?
  logoUrl        String?
  receiptHeader    String?
  receiptSubHeader String?
  themePrimary     String?
  themeSecondary   String?
  printerConfig    Json?
  barUnitMl        Int             @default(30)
  fullBottleMl     Int             @default(750)
  halfBottleMl     Int             @default(375)
  fssai            String?
  pricesIncludeGst Boolean         @default(false)
  gstCategory      String          @default("NON_AC") // NON_AC | AC | TAKEAWAY — drives bill format
  gstRate          Float?          // null = auto from category; set = owner override
  gstRegistered    Boolean         @default(true)  // if false, no GST shown on bills
  serviceChargePercent Int         @default(0)
  deliveryPlatforms String[]
  enabledModules   Json?
  sharedKitchenOutletId String?  // when set, kitchen inventory is scoped to this outlet instead of self
  planPriceSnapshot    Decimal?  @db.Decimal(10, 2)
  paymentReference      String?
  onboardingCompletedAt DateTime?
  isActive              Boolean        @default(true)
  createdAt             DateTime       @default(now())
  updatedAt             DateTime       @updatedAt
  venuesMigrated        Boolean        @default(false)
  organizationId        String
  organization          Organization   @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  outletAccess          OutletAccess[]
  sections              Section[]
  users                 User[]
  venues                Venue[]
  venuePrices           VenuePrice[]
  venueMenuItemAvailability VenueMenuItemAvailability[]

  @@index([parentRestaurantId])
  @@index([organizationId])
  @@index([sharedKitchenOutletId])
}

model Organization {
  id             String    @id @default(cuid())
  name           String
  plan           String    @default("starter")
  subscriptionId String?
  billingStatus  String    @default("trialing")
  trialEndsAt    DateTime?
  paymentStatus  String    @default("LEGACY_EXEMPT")
  features       Json?
  enabledModules Json?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  outlets        Outlet[]
}

model OnboardingPayment {
  id               String   @id @default(cuid())
  sessionId        String
  restaurantId     String?
  plan             String
  numberOfOutlets  Int
  amount           Decimal  @db.Decimal(10, 2)
  currency         String   @default("INR")
  gateway          String   @default("MOCK")
  status           String   @default("CREATED")
  gatewayOrderId   String?
  gatewayPaymentId String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@index([sessionId])
  @@index([restaurantId])
}

model User {
  id               String                  @id @default(cuid())
  name             String
  email            String?                 @unique
  passwordHash     String?
  pin              String?
  isActive         Boolean                 @default(true)
  resetToken       String?
  resetTokenAt     DateTime?
  createdAt        DateTime                @default(now())
  updatedAt        DateTime                @updatedAt
  venueId          String?
  permissions      Json?                   @default("{}")
  role             UserRole
  outletId         String
  employee         Employee?
  outletAccess     OutletAccess[]
  advanceHistory   PayrollAdvanceHistory[] @relation("PayrollAdvanceHistoryCreator")
  outlet           Outlet                  @relation(fields: [outletId], references: [id])
  approvedVouchers Voucher[]               @relation("VoucherApprover")
  createdVouchers  Voucher[]               @relation("VoucherCreator")

  @@unique([outletId, email])
  @@index([outletId])
  @@index([email])
}

model OutletAccess {
  id          String   @id @default(cuid())
  userId      String
  outletId    String
  role        UserRole
  permissions Json?    @default("{}")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  outlet      Outlet   @relation(fields: [outletId], references: [id], onDelete: Cascade)
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, outletId])
  @@index([userId])
  @@index([outletId])
}

model Category {
  id            String     @id @default(uuid())
  name          String
  printerTarget String?    // Actual printer name (e.g. "Kitchen Printer") or legacy enum "BAR_PRINTER" | "KOT_PRINTER" | null
  sortOrder     Int        @default(0)
  isActive      Boolean    @default(true)
  restaurantId  String
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt
  items         MenuItem[]

  @@index([restaurantId])
  @@index([restaurantId, isActive, sortOrder])
}

model MenuItem {
  id                String             @id @default(uuid())
  name              String
  description       String?
  imageUrl          String?
  basePrice         Decimal            @default(0) @db.Decimal(10, 2)
  isVeg             Boolean            @default(true)
  isAvailable       Boolean            @default(true)
  isDeleted         Boolean            @default(false)
  deletedAt         DateTime?
  gstEnabled        Boolean            @default(true)
  menuType          MenuType           @default(FOOD)
  printerTarget     String?            // Actual printer name (e.g. "Kitchen Printer") or legacy enum "BAR_PRINTER" | "KOT_PRINTER" | null (falls back to category)
  printerName       String?            // Physical Windows printer name override (highest priority)
  sortOrder         Int                @default(0)
  unit              String?            @db.VarChar(20)
  categoryId        String
  category          Category           @relation(fields: [categoryId], references: [id])
  restaurantId      String
  variants          MenuItemVariant[]
  addons            MenuItemAddon[]
  orderItems        OrderItem[]
  inventoryItem     InventoryItem?
  venuePrices       VenuePrice[]
  priceProfileItems PriceProfileItem[]
  recipes           MenuItemRecipe[]
  venueAvailabilities VenueMenuItemAvailability[]
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt

  @@index([categoryId])
  @@index([restaurantId])
  @@index([restaurantId, isAvailable, isDeleted])
}

model MenuItemVariant {
  id           String   @id @default(uuid())
  name         String
  price        Decimal  @db.Decimal(10, 2)
  isDefault    Boolean  @default(false)
  menuItemId   String
  isAvailable  Boolean  @default(true)
  restaurantId String
  menuItem     MenuItem @relation(fields: [menuItemId], references: [id], onDelete: Cascade)

  @@index([menuItemId])
  @@index([restaurantId])
}

model MenuItemAddon {
  id           String   @id @default(uuid())
  name         String
  price        Decimal  @db.Decimal(10, 2)
  isAvailable  Boolean  @default(true)
  menuItemId   String
  restaurantId String
  menuItem     MenuItem @relation(fields: [menuItemId], references: [id], onDelete: Cascade)

  @@index([menuItemId])
  @@index([restaurantId])
}

model Section {
  id           String        @id @default(cuid())
  name         String
  restaurantId String
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  floorId      String?
  sortOrder    Int           @default(0)
  venueId      String?
  floor        Floor?        @relation(fields: [floorId], references: [id])
  outlet       Outlet        @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  venue        Venue?        @relation(fields: [venueId], references: [id])
  tables       Table[]
  transactions Transaction[]

  @@index([restaurantId])
  @@index([venueId])
  @@index([floorId])
}

model Table {
  id               String      @id @default(cuid())
  number           Int
  capacity         Int         @default(4)
  status           TableStatus @default(AVAILABLE)
  sectionId        String
  restaurantId     String
  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt
  workflowStatus   String?
  captainId        String?
  guests           Int         @default(0)
  sessionStartedAt DateTime?
  currentBill      Decimal     @default(0) @db.Decimal(10, 2)
  kotHistory       Json        @default("[]")
  discount         Decimal?    @db.Decimal(5, 2)
  sectionTag       String?
  lastWaiterCallAt DateTime?
  orders           Order[]
  section          Section     @relation(fields: [sectionId], references: [id])

  @@unique([restaurantId, sectionId, number])
  @@index([restaurantId, status])
}

model TaxProfile {
  id                   String   @id @default(cuid())
  restaurantId         String
  name                 String
  gstCategory          String   @default("NON_AC")
  gstRate              Float?
  gstRegistered        Boolean  @default(true)
  serviceChargePercent Int      @default(0)
  isDefault            Boolean  @default(false)
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
  venues               Venue[]

  @@index([restaurantId])
}

model PriceProfile {
  id           String             @id @default(cuid())
  restaurantId String
  name         String
  isDefault    Boolean            @default(false)
  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt
  items        PriceProfileItem[]
  venues       Venue[]

  @@index([restaurantId])
}

model PriceProfileItem {
  id             String       @id @default(cuid())
  priceProfileId String
  menuItemId     String
  price          Decimal      @db.Decimal(10, 2)
  restaurantId   String
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  menuItem       MenuItem     @relation(fields: [menuItemId], references: [id], onDelete: Cascade)
  priceProfile   PriceProfile @relation(fields: [priceProfileId], references: [id], onDelete: Cascade)

  @@unique([priceProfileId, menuItemId])
  @@index([priceProfileId])
  @@index([menuItemId])
  @@index([restaurantId])
}

model Venue {
  id              String        @id @default(cuid())
  restaurantId    String
  name            String
  venueType       String        @default("DINE_IN")
  sortOrder       Int           @default(0)
  isActive        Boolean       @default(true)
  isDeleted       Boolean       @default(false)
  priceProfileId  String?
  taxProfileId    String?
  kotPrinterName  String?
  billPrinterName String?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  kotEnabled      Boolean       @default(true)
  floors          Floor[]
  sections        Section[]
  priceProfile    PriceProfile? @relation(fields: [priceProfileId], references: [id])
  restaurant      Outlet        @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  taxProfile      TaxProfile?   @relation(fields: [taxProfileId], references: [id])

  @@index([restaurantId])
}

model Floor {
  id           String    @id @default(cuid())
  venueId      String
  restaurantId String
  name         String
  sortOrder    Int       @default(0)
  isActive     Boolean   @default(true)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  venue        Venue     @relation(fields: [venueId], references: [id], onDelete: Cascade)
  sections     Section[]

  @@index([venueId])
  @@index([restaurantId])
}

model Order {
  id                 String       @id @default(cuid())
  tableId            String
  restaurantId       String
  status             OrderStatus  @default(PENDING)
  totalAmount        Decimal      @default(0) @db.Decimal(10, 2)
  billingRequested   Boolean      @default(false)
  billingRequestedAt DateTime?
  createdAt          DateTime     @default(now())
  updatedAt          DateTime     @updatedAt
  isDeleted          Boolean      @default(false)
  deletedAt          DateTime?
  billNumber         String?
  paidAt             DateTime?
  lastRequestId      String?
  inventoryDeducted  Boolean      @default(false)
  platform           String?      @default("DINE_IN")
  table              Table        @relation(fields: [tableId], references: [id])
  items              OrderItem[]
  transactions       Transaction?

  @@index([restaurantId, status])
  @@index([tableId, status])
  @@index([restaurantId, isDeleted])
  @@index([restaurantId, status, paidAt(sort: Desc)])
}

model OrderItem {
  id                String    @id @default(cuid())
  orderId           String
  menuItemId        String
  name              String
  price             Decimal   @db.Decimal(10, 2)
  quantity          Int
  notes             String?
  addedByCashier    Boolean   @default(false)
  originalQuantity  Int?
  cancelledQuantity Int       @default(0)
  editedQuantity    Int       @default(0)
  removedFromBill   Boolean   @default(false)
  removedBy         String?
  removedAt         DateTime?
  menuType          MenuType  @default(FOOD)
  menuItem          MenuItem  @relation(fields: [menuItemId], references: [id])
  order             Order     @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId])
  @@index([menuItemId])
  @@index([orderId, removedFromBill])
}

model Transaction {
  id              String   @id @default(cuid())
  restaurantId    String
  orderId         String?  @unique
  tableNumber     Int?
  captainId       String?
  amount          Decimal  @db.Decimal(10, 2)
  method          String
  itemCount       Int      @default(0)
  items           Json     @default("[]")
  sectionTag      String?
  txnNumber       Int      @default(0)
  txnDate         String   @default("")
  paidAt          DateTime @default(now())
  createdAt       DateTime @default(now())
  subtotal        Decimal? @db.Decimal(10, 2)
  discountPercent Decimal? @db.Decimal(5, 2)
  discountAmount  Decimal? @db.Decimal(10, 2)
  cgst            Decimal? @db.Decimal(10, 2)
  sgst            Decimal? @db.Decimal(10, 2)
  grandTotal      Decimal? @db.Decimal(10, 2)
  billNumber      String?
  tableLabel      String?
  sectionId       String?
  platform        String?
  order           Order?   @relation(fields: [orderId], references: [id])
  section         Section? @relation(fields: [sectionId], references: [id])

  @@index([restaurantId])
  @@index([restaurantId, paidAt(sort: Desc)])
  @@index([restaurantId, txnDate])
  @@index([restaurantId, sectionId])
}

model DailyCounter {
  id           String   @id @default(cuid())
  restaurantId String
  counterDate  String
  kotCount     Int      @default(0)
  billCount    Int      @default(0)
  txnCount     Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  voucherCount Int      @default(0)

  @@unique([restaurantId, counterDate])
  @@index([restaurantId, counterDate])
}

model ProcessedRequest {
  id           String   @id @default(cuid())
  requestId    String
  actionType   String
  orderId      String?
  restaurantId String
  result       Json?
  createdAt    DateTime @default(now())
  deviceId     String?

  @@unique([requestId, actionType, restaurantId])
  @@index([restaurantId, createdAt])
  @@index([deviceId, restaurantId])
}

model CaptainAssignment {
  id            String   @id @default(cuid())
  restaurantId  String
  captainId     String
  revenueTarget Decimal  @db.Decimal(10, 2)
  discountLimit Decimal  @db.Decimal(10, 2)
  assignedAt    DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@unique([restaurantId, captainId])
  @@index([restaurantId])
  @@index([captainId])
}

model InventoryItem {
  id             String                   @id @default(cuid())
  menuItemId     String                   @unique
  restaurantId   String
  unitOfMeasure  String
  bottleSize     Int
  openingStock   Decimal                  @db.Decimal(10, 2)
  currentStock   Decimal                  @db.Decimal(10, 2)
  reorderLevel   Decimal                  @db.Decimal(10, 2)
  costPerBottle  Decimal?                 @db.Decimal(10, 2)
  lastRestocked  DateTime?
  createdAt      DateTime                 @default(now())
  updatedAt      DateTime                 @updatedAt
  dailySnapshots DailyInventorySnapshot[]
  menuItem       MenuItem                 @relation(fields: [menuItemId], references: [id], onDelete: Cascade)
  transactions   InventoryTransaction[]

  @@index([restaurantId])
  @@index([menuItemId])
  @@index([currentStock])
  @@map("inventory_items")
}

model InventoryTransaction {
  id              String        @id @default(cuid())
  restaurantId    String
  itemId          String
  orderId         String?
  type            String
  quantityChange  Decimal       @db.Decimal(10, 2)
  stockBefore     Decimal       @db.Decimal(10, 2)
  stockAfter      Decimal       @db.Decimal(10, 2)
  notes           String?
  createdBy       String?
  transactionDate DateTime      @default(now())
  item            InventoryItem @relation(fields: [itemId], references: [id], onDelete: Cascade)

  @@index([restaurantId, transactionDate])
  @@index([itemId])
  @@index([orderId])
  @@index([type])
  @@map("inventory_transactions")
}

model DailyInventorySnapshot {
  id           String        @id @default(cuid())
  restaurantId String
  snapshotDate String
  itemId       String
  itemName     String
  openingStock Decimal       @db.Decimal(10, 2)
  purchased    Decimal       @db.Decimal(10, 2)
  sold         Decimal       @db.Decimal(10, 2)
  wastage      Decimal       @db.Decimal(10, 2)
  adjusted     Decimal       @db.Decimal(10, 2)
  closingStock Decimal       @db.Decimal(10, 2)
  createdAt    DateTime      @default(now())
  item         InventoryItem @relation(fields: [itemId], references: [id], onDelete: Cascade)

  @@unique([restaurantId, snapshotDate, itemId])
  @@index([restaurantId, snapshotDate])
  @@map("daily_inventory_snapshots")
}

model VenuePrice {
  id           String   @id @default(cuid())
  venueId      String
  menuItemId   String
  price        Decimal  @db.Decimal(10, 2)
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  restaurantId String
  menuItem     MenuItem @relation(fields: [menuItemId], references: [id], onDelete: Cascade)
  restaurant   Outlet   @relation(fields: [restaurantId], references: [id], onDelete: Cascade)

  @@unique([venueId, menuItemId])
  @@index([venueId])
  @@index([menuItemId])
  @@index([restaurantId])
}

// ---------------------------------------------------------------------------
// Venue Menu Item Availability — per-venue hide/unhide (not price)
// ---------------------------------------------------------------------------
model VenueMenuItemAvailability {
  id           String   @id @default(cuid())
  venueId      String
  menuItemId   String
  menuItem     MenuItem @relation(fields: [menuItemId], references: [id], onDelete: Cascade)
  restaurantId String
  restaurant   Outlet   @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  isAvailable  Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@unique([venueId, menuItemId])
  @@index([venueId])
  @@index([menuItemId])
  @@index([restaurantId])
}

// ---------------------------------------------------------------------------
// PrintQueue — persistent print job buffer for reconnect recovery
// ---------------------------------------------------------------------------
model PrintQueue {
  id           String    @id @default(cuid())
  restaurantId String
  eventId      String    @unique
  payload      Json
  status       String    @default("PENDING")
  createdAt    DateTime  @default(now())
  printedAt    DateTime?

  @@index([restaurantId, status])
  @@index([createdAt])
}

model Employee {
  id             String                  @id @default(cuid())
  restaurantId   String
  name           String
  age            Int?
  role           String?
  baseSalary     Decimal                 @db.Decimal(10, 2)
  joinDate       DateTime                @default(now())
  isActive       Boolean                 @default(true)
  createdAt      DateTime                @default(now())
  updatedAt      DateTime                @updatedAt
  idempotencyKey String?
  userId         String?                 @unique
  staffCode      String?
  attendance     Attendance[]
  user           User?                   @relation(fields: [userId], references: [id])
  advanceHistory PayrollAdvanceHistory[] @relation("PayrollAdvanceHistoryEmployee")
  payrolls       PayrollRecord[]         @relation("PayrollEmployee")
  vouchers       Voucher[]               @relation("VoucherEmployee")

  @@unique([restaurantId, staffCode])
  @@index([restaurantId])
  @@index([idempotencyKey, restaurantId])
  @@index([userId])
}

model PayrollRecord {
  id                  String                  @id @default(cuid())
  restaurantId        String
  employeeId          String
  monthYear           String
  baseSalary          Decimal                 @db.Decimal(10, 2)
  absentDays          Int                     @default(0)
  advanceAmount       Decimal                 @default(0) @db.Decimal(10, 2)
  otDays              Int                     @default(0)
  otAmount            Decimal                 @default(0) @db.Decimal(10, 2)
  netPayable          Decimal                 @db.Decimal(10, 2)
  paidAmount          Decimal                 @default(0) @db.Decimal(10, 2)
  status              String                  @default("PENDING")
  notes               String?
  createdAt           DateTime                @default(now())
  updatedAt           DateTime                @updatedAt
  manualAdvanceAmount Decimal                 @default(0) @db.Decimal(10, 2)
  periodEnd           String?
  periodStart         String?
  presentDays         Float                   @default(0)
  advanceHistory      PayrollAdvanceHistory[] @relation("PayrollAdvanceHistoryRecord")
  employee            Employee                @relation("PayrollEmployee", fields: [employeeId], references: [id], onDelete: Cascade)
  vouchers            Voucher[]               @relation("VoucherPayrollRecord")

  @@unique([employeeId, monthYear])
  @@index([restaurantId, monthYear])
}

model PayrollAdvanceHistory {
  id              String         @id @default(cuid())
  restaurantId    String
  employeeId      String
  payrollRecordId String?
  amount          Decimal        @db.Decimal(10, 2)
  reason          String?
  date            String
  createdById     String
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  createdBy       User           @relation("PayrollAdvanceHistoryCreator", fields: [createdById], references: [id])
  employee        Employee       @relation("PayrollAdvanceHistoryEmployee", fields: [employeeId], references: [id], onDelete: Cascade)
  payrollRecord   PayrollRecord? @relation("PayrollAdvanceHistoryRecord", fields: [payrollRecordId], references: [id])

  @@index([restaurantId])
  @@index([employeeId])
  @@index([payrollRecordId])
  @@index([createdById])
}

model Attendance {
  id           String    @id @default(cuid())
  restaurantId String
  employeeId   String
  date         String
  status       String
  checkInTime  DateTime?
  checkOutTime DateTime?
  notes        String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  employee     Employee  @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@unique([employeeId, date])
  @@index([restaurantId, date])
  @@index([employeeId])
}

model KitchenInventoryItem {
  id            String            @id @default(cuid())
  restaurantId  String
  name          String
  category      String?
  unit          String
  currentStock  Decimal           @db.Decimal(10, 2)
  price         Decimal           @default(0) @db.Decimal(10, 2)
  reorderLevel  Decimal           @default(0) @db.Decimal(10, 2)
  image         String?
  recipes       MenuItemRecipe[]
  dailyEntries  InventoryDailyEntry[]
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt

  @@unique([restaurantId, name])
  @@index([restaurantId])
}

model MenuItemRecipe {
  id            String              @id @default(cuid())
  menuItemId    String
  menuItem      MenuItem            @relation(fields: [menuItemId], references: [id], onDelete: Cascade)
  ingredientId  String
  ingredient    KitchenInventoryItem @relation(fields: [ingredientId], references: [id], onDelete: Cascade)
  quantity      Decimal             @db.Decimal(10, 2)
  restaurantId  String

  @@unique([menuItemId, ingredientId])
  @@index([restaurantId])
}

model InventoryDailyEntry {
  id            String               @id @default(cuid())
  restaurantId  String
  entryDate     String
  itemId        String
  openingStock  Decimal              @db.Decimal(10, 2)
  addedStock    Decimal              @default(0) @db.Decimal(10, 2)
  consumedStock Decimal              @default(0) @db.Decimal(10, 2)
  closingStock  Decimal              @db.Decimal(10, 2)
  item          KitchenInventoryItem @relation(fields: [itemId], references: [id], onDelete: Cascade)
  createdAt     DateTime             @default(now())
  updatedAt     DateTime             @updatedAt

  @@unique([restaurantId, itemId, entryDate])
  @@index([restaurantId, entryDate])
}

model AuditLog {
  id           String   @id @default(cuid())
  userId       String?
  restaurantId String?
  action       String
  entityType   String
  entityId     String?
  metadata     Json?
  createdAt    DateTime @default(now())

  @@index([restaurantId, createdAt])
  @@index([userId])
  @@index([entityType, entityId])
}

model PlanConfig {
  id                  String   @id @default(cuid())
  planId              String   @unique
  name                String
  basePrice           Int
  perExtraOutletPrice Int
  includedOutlets     Int
  isCustomQuote       Boolean  @default(false)
  isActive            Boolean  @default(true)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
}

model FeatureFlag {
  id                 String   @id @default(cuid())
  key                String   @unique
  description        String?
  enabledGlobally    Boolean  @default(false)
  enabledRestaurants String[] @default([])
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
}

model Announcement {
  id          String    @id @default(cuid())
  title       String
  body        String
  type        String    @default("info")
  target      String    @default("all")
  isActive    Boolean   @default(true)
  activeFrom  DateTime?
  activeUntil DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([isActive, activeFrom, activeUntil])
}

model Voucher {
  id              String         @id @default(cuid())
  restaurantId    String
  voucherNo       Int
  voucherDate     String
  paidToType      String
  paidToName      String
  employeeId      String?
  amount          Decimal        @db.Decimal(10, 2)
  narration       String?
  approvedById    String?
  createdById     String
  status          String         @default("UNVERIFIED")
  payrollRecordId String?
  idempotencyKey  String?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  approvedBy      User?          @relation("VoucherApprover", fields: [approvedById], references: [id])
  createdBy       User           @relation("VoucherCreator", fields: [createdById], references: [id])
  employee        Employee?      @relation("VoucherEmployee", fields: [employeeId], references: [id])
  payrollRecord   PayrollRecord? @relation("VoucherPayrollRecord", fields: [payrollRecordId], references: [id])

  @@index([restaurantId, voucherDate])
  @@index([restaurantId, status])
  @@index([employeeId])
  @@index([idempotencyKey, restaurantId])
}

enum UserRole {
  OWNER
  ADMIN
  CASHIER
  CAPTAIN
  KITCHEN
}

enum MenuType {
  FOOD
  LIQUOR
}

enum TableStatus {
  AVAILABLE
  OCCUPIED
  RESERVED
  CLEANING
  BILLING_REQUESTED
}

enum OrderStatus {
  PENDING
  CONFIRMED
  PREPARING
  READY
  BILLING_REQUESTED
  PAID
  CANCELLED
}
