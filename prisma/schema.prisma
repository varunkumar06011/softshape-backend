generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// TIP: Append ?connection_limit=20&pool_timeout=30 to DATABASE_URL env var
//      (Prisma reads pool settings from the connection-string query params.)

// ---------------------------------------------------------------------------
// Outlet — multi-tenancy root & receipt generation
// ---------------------------------------------------------------------------
model Outlet {
  id             String   @id @default(cuid())
  name           String
  slug           String   @unique
  restaurantCode String   @unique
  restaurantType String?  // DINE_IN | BAR_LOUNGE | BAR_WITH_DINING | CAFE | CLOUD_KITCHEN
  outletCount    Int      @default(1)
  parentRestaurantId String? // for multi-outlet: child references parent
  parent         Outlet? @relation("OutletRelation", fields: [parentRestaurantId], references: [id], onDelete: SetNull)
  outlets        Outlet[] @relation("OutletRelation")
  address        String?
  phone          String?
  email          String?
  gstin          String?
  logoUrl        String?
  receiptHeader    String?
  receiptSubHeader String?
  themePrimary     String?
  themeSecondary   String?
  printerConfig    Json?
  barUnitMl        Int             @default(30)
  fullBottleMl     Int             @default(750)
  halfBottleMl     Int             @default(375)
  fssai            String?
  pricesIncludeGst Boolean         @default(false)
  gstCategory      String          @default("NON_AC") // NON_AC | AC | TAKEAWAY — drives bill format
  gstRate          Float?          // null = auto from category; set = owner override
  gstRegistered    Boolean         @default(true)  // if false, no GST shown on bills
  serviceChargePercent Int         @default(0)
  deliveryPlatforms String[]
  planPriceSnapshot    Decimal?  @db.Decimal(10, 2)
  paymentReference      String?
  onboardingCompletedAt DateTime?
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  users          User[]
  outletAccess   OutletAccess[]
  venuePrices    VenuePrice[]
  venuesMigrated Boolean   @default(false)
  venues         Venue[]
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: SetNull)

  @@index([parentRestaurantId])
  @@index([organizationId])
}

// ---------------------------------------------------------------------------
// Organization — billing & plan root for one or more outlets
// ---------------------------------------------------------------------------
model Organization {
  id             String   @id @default(cuid())
  name           String
  plan           String   @default("starter")
  subscriptionId String?
  billingStatus  String   @default("trialing")
  trialEndsAt    DateTime?
  paymentStatus  String   @default("LEGACY_EXEMPT")
  features       Json?
  enabledModules Json?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  outlets        Outlet[]
}

// ---------------------------------------------------------------------------
// Onboarding Payment — gateway-agnostic audit trail for new tenant onboarding
// ---------------------------------------------------------------------------
model OnboardingPayment {
  id                String   @id @default(cuid())
  sessionId         String   // client-generated UUID for the wizard session
  restaurantId      String?  // null until the restaurant row exists; backfilled after creation
  plan              String
  numberOfOutlets   Int
  amount            Decimal  @db.Decimal(10, 2)
  currency          String   @default("INR")
  gateway           String   @default("MOCK") // "MOCK" | "RAZORPAY" | "STRIPE" (future)
  status            String   @default("CREATED") // "CREATED" | "SUCCESS" | "FAILED"
  gatewayOrderId    String?
  gatewayPaymentId  String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@index([sessionId])
  @@index([restaurantId])
}

// ---------------------------------------------------------------------------
// User & Roles
// ---------------------------------------------------------------------------
enum UserRole {
  OWNER
  ADMIN
  CASHIER
  CAPTAIN
  KITCHEN
}

model User {
  id           String     @id @default(cuid())
  name         String
  email        String?
  passwordHash String?
  pin          String?
  role         UserRole
  outletId     String
  outlet       Outlet     @relation(fields: [outletId], references: [id])
  isActive     Boolean    @default(true)
  resetToken   String?
  resetTokenAt DateTime?
  venueId      String?   // if set, this staff member is scoped to one venue only
  permissions  Json?      @default("{}")
  outletAccess OutletAccess[]
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  @@index([outletId])
  @@index([email])
  @@unique([outletId, email])
  @@unique([outletId, id])
}

// ---------------------------------------------------------------------------
// Outlet Access — per-outlet role & permissions for multi-outlet users
// ---------------------------------------------------------------------------
model OutletAccess {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  outletId    String
  outlet      Outlet     @relation(fields: [outletId], references: [id], onDelete: Cascade)
  role        UserRole
  permissions Json?    @default("{}")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([userId, outletId])
  @@index([userId])
  @@index([outletId])
}

// ---------------------------------------------------------------------------
// Menu
// ---------------------------------------------------------------------------
model Category {
  id            String     @id @default(uuid())
  name          String
  printerTarget String?    // "KOT_PRINTER" | "BAR_PRINTER" | null (falls back to category-name heuristic)
  sortOrder     Int        @default(0)
  isActive      Boolean    @default(true)
  restaurantId  String
  items         MenuItem[]
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt

  @@index([restaurantId])
  @@index([restaurantId, isActive, sortOrder])
  @@unique([restaurantId, id])
}

model MenuItem {
  id            String            @id @default(uuid())
  name          String
  description   String?
  imageUrl      String?
  basePrice     Decimal           @default(0) @db.Decimal(10, 2)
  isVeg         Boolean           @default(true)
  isAvailable   Boolean           @default(true)
  isDeleted     Boolean           @default(false)
  deletedAt     DateTime?
  menuType      MenuType          @default(FOOD)
  printerTarget String?           // "KOT_PRINTER" | "BAR_PRINTER" | null (falls back to category)
  printerName   String?           // physical printer name from printerConfig.printers[]
  sortOrder     Int               @default(0)
  unit          String?           @db.VarChar(20)
  categoryId    String
  category      Category          @relation(fields: [categoryId], references: [id])
  restaurantId  String
  variants      MenuItemVariant[]
  addons        MenuItemAddon[]
  orderItems    OrderItem[]
  inventoryItem     InventoryItem?
  venuePrices       VenuePrice[]
  priceProfileItems PriceProfileItem[]
  recipes           MenuItemRecipe[]
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt

  @@index([categoryId])
  @@index([restaurantId])
  @@index([restaurantId, isAvailable, isDeleted])
  @@unique([restaurantId, id])
}

model MenuItemVariant {
  id          String   @id @default(uuid())
  name        String
  price       Decimal  @db.Decimal(10, 2)
  isDefault   Boolean  @default(false)
  isAvailable Boolean  @default(true)
  menuItemId  String
  menuItem    MenuItem @relation(fields: [menuItemId], references: [id], onDelete: Cascade)

  @@index([menuItemId])
}

model MenuItemAddon {
  id          String   @id @default(uuid())
  name        String
  price       Decimal  @db.Decimal(10, 2)
  isAvailable Boolean  @default(true)
  menuItemId  String
  menuItem    MenuItem @relation(fields: [menuItemId], references: [id], onDelete: Cascade)

  @@index([menuItemId])
}

enum MenuType {
  FOOD
  LIQUOR
}

// ---------------------------------------------------------------------------
// Floor plan
// ---------------------------------------------------------------------------
model Section {
  id           String   @id @default(cuid())
  name         String
  restaurantId String
  venueId      String?          // NEW — which venue this section belongs to
  venue        Venue?    @relation(fields: [venueId], references: [id], onDelete: SetNull)
  floorId      String?          // NEW — which floor (optional level)
  floor        Floor?    @relation(fields: [floorId], references: [id], onDelete: SetNull)
  sortOrder    Int       @default(0)
  tables       Table[]
  transactions Transaction[]
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@unique([restaurantId, id])
  @@index([venueId])
  @@index([floorId])
}

model Table {
  id               String      @id @default(cuid())
  number           Int
  capacity         Int         @default(4)
  status           TableStatus @default(AVAILABLE)
  workflowStatus   String?
  captainId        String?
  guests           Int         @default(0)
  sessionStartedAt DateTime?
  discount         Decimal?    @db.Decimal(5, 2)
  currentBill      Decimal     @default(0) @db.Decimal(10, 2)
  kotHistory       Json        @default("[]")
  sectionId        String
  section          Section     @relation(fields: [sectionId], references: [id])
  restaurantId     String
  sectionTag       String?     // e.g. "venue-bar-parcel", "venue-restaurant-parcel", "venue-bar-conference"
  lastWaiterCallAt DateTime?   // last waiter call timestamp for cooldown enforcement
  orders           Order[]
  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt

  @@unique([restaurantId, sectionId, number])
  @@index([restaurantId, status])
  @@unique([restaurantId, id])
}

enum TableStatus {
  AVAILABLE
  OCCUPIED
  BILLING_REQUESTED
  RESERVED
  CLEANING
}

// ---------------------------------------------------------------------------
// Tax Profiles
// ---------------------------------------------------------------------------
model TaxProfile {
  id                   String   @id @default(cuid())
  restaurantId         String
  name                 String   // "AC Hall", "Non-AC", "Bar", "Takeaway"
  gstCategory          String   @default("NON_AC") // NON_AC | AC | TAKEAWAY
  gstRate              Float?   // null = auto from category
  gstRegistered        Boolean  @default(true)
  serviceChargePercent Int      @default(0)
  isDefault            Boolean  @default(false)
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
  venues               Venue[]

  @@index([restaurantId])
  @@unique([restaurantId, id])
}

// ---------------------------------------------------------------------------
// Price Profiles
// ---------------------------------------------------------------------------
model PriceProfile {
  id           String             @id @default(cuid())
  restaurantId String
  name         String             // "Regular", "AC", "Bar", "Happy Hour", "Zomato"
  isDefault    Boolean            @default(false)
  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt
  items        PriceProfileItem[]
  venues       Venue[]

  @@index([restaurantId])
  @@unique([restaurantId, id])
}

model PriceProfileItem {
  id             String       @id @default(cuid())
  priceProfileId String
  priceProfile   PriceProfile @relation(fields: [priceProfileId], references: [id], onDelete: Cascade)
  menuItemId     String
  menuItem       MenuItem     @relation(fields: [menuItemId], references: [id], onDelete: Cascade)
  price          Decimal      @db.Decimal(10, 2)
  restaurantId   String
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@unique([priceProfileId, menuItemId])
  @@index([priceProfileId])
  @@index([menuItemId])
  @@index([restaurantId])
}

// ---------------------------------------------------------------------------
// Venues & Floors
// ---------------------------------------------------------------------------
model Venue {
  id             String   @id @default(cuid())
  restaurantId   String
  restaurant     Outlet     @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  name           String   // "Restaurant", "Bar", "Banquet Hall", "Conference", "PDR", "Takeaway"
  venueType      String   @default("DINE_IN") // DINE_IN | TAKEAWAY | DELIVERY | ROOM_SERVICE | BANQUET | CONFERENCE | BAR | PDR | CAFE
  sortOrder      Int      @default(0)
  isActive       Boolean  @default(true)
  isDeleted      Boolean  @default(false)

  // Profile references (all nullable = fall back to restaurant defaults)
  priceProfileId String?
  priceProfile   PriceProfile? @relation(fields: [priceProfileId], references: [id], onDelete: SetNull)
  taxProfileId   String?
  taxProfile     TaxProfile?   @relation(fields: [taxProfileId], references: [id], onDelete: SetNull)

  // Printer assignments
  kotPrinterName  String?  // maps to printerConfig key
  billPrinterName String?

  floors   Floor[]
  sections Section[] // direct sections if no floors needed

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([restaurantId])
  @@unique([restaurantId, id])
}

model Floor {
  id           String   @id @default(cuid())
  venueId      String
  venue        Venue    @relation(fields: [venueId], references: [id], onDelete: Cascade)
  restaurantId String
  name         String   // "Floor 1", "Ground Floor", "Rooftop"
  sortOrder    Int      @default(0)
  isActive     Boolean  @default(true)
  sections     Section[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([venueId])
  @@index([restaurantId])
  @@unique([restaurantId, id])
}

// ---------------------------------------------------------------------------
// Orders
// ---------------------------------------------------------------------------
model Order {
  id                 String        @id @default(cuid())
  tableId            String
  table              Table         @relation(fields: [tableId], references: [id])
  restaurantId       String
  status             OrderStatus   @default(PENDING)
  lastRequestId      String?
  items              OrderItem[]
  transactions       Transaction[]
  totalAmount        Decimal       @default(0) @db.Decimal(10, 2)
  billNumber         String?
  billingRequested   Boolean       @default(false)
  billingRequestedAt DateTime?
  paidAt             DateTime?
  inventoryDeducted  Boolean       @default(false)   // ← ADD THIS LINE
  platform           String?       @default("DINE_IN") // DINE_IN | SWIGGY | ZOMATO | DIRECT | ...
  isDeleted          Boolean       @default(false)
  deletedAt          DateTime?
  createdAt          DateTime      @default(now())
  updatedAt          DateTime      @updatedAt

  @@index([restaurantId, status])
  @@index([tableId, status])
  @@index([restaurantId, isDeleted])
  @@unique([restaurantId, id])
}

enum OrderStatus {
  PENDING
  CONFIRMED
  PREPARING
  READY
  BILLING_REQUESTED
  PAID
  CANCELLED
}

model OrderItem {
  id              String    @id @default(cuid())
  orderId         String
  order           Order     @relation(fields: [orderId], references: [id], onDelete: Cascade)
  menuItemId      String
  menuItem        MenuItem  @relation(fields: [menuItemId], references: [id])
  name            String
  price           Decimal   @db.Decimal(10, 2)
  quantity        Int
  notes           String?
  menuType        MenuType  @default(FOOD)
  originalQuantity Int?
  cancelledQuantity Int      @default(0)
  editedQuantity   Int       @default(0)
  removedFromBill Boolean   @default(false)
  removedBy       String?
  removedAt       DateTime?
  addedByCashier  Boolean   @default(false)

  @@index([orderId])
  @@index([menuItemId])
}

// ---------------------------------------------------------------------------
// Billing
// ---------------------------------------------------------------------------
model Transaction {
  id           String   @id @default(cuid())
  restaurantId String
  orderId      String?  @unique // one payment record per order; null rows are exempt (PostgreSQL allows multiple NULLs)
  order        Order?   @relation(fields: [orderId], references: [id], onDelete: SetNull)
  tableNumber  Int?
  captainId    String?
  amount       Decimal  @db.Decimal(10, 2)
  method       String // CASH | CARD | UPI | SPLIT
  itemCount    Int      @default(0)
  items        Json     @default("[]")
  subtotal        Decimal?  @db.Decimal(10, 2)
  discountPercent Decimal?  @db.Decimal(5, 2)
  discountAmount  Decimal?  @db.Decimal(10, 2)
  cgst            Decimal?  @db.Decimal(10, 2)
  sgst            Decimal?  @db.Decimal(10, 2)
  grandTotal      Decimal?  @db.Decimal(10, 2)
  sectionTag   String?  // venue-bar-parcel | venue-bar-ac-hall | venue-bar-conference | venue-bar-pdr | venue-bar-rooms | venue-bar-gobox | venue-restaurant-parcel | venue-family-restaurant
  sectionId    String?  // generic section reference for filtering; sectionTag remains for legacy print logic
  section      Section? @relation(fields: [sectionId], references: [id])
  platform     String?  // copied from Order.platform at settlement
  txnNumber    Int      @default(0) // daily sequential: 1, 2, 3…
  txnDate      String   @default("") // YYYY-MM-DD in IST — for daily reset
  billNumber   String?  // copied from Order.billNumber at settlement / print-bill
  tableLabel   String?  // extra table display name e.g. "B1-X"; null for regular tables
  paidAt       DateTime @default(now())
  createdAt    DateTime @default(now())

  @@index([restaurantId])
  @@index([restaurantId, paidAt(sort: Desc)])
  @@index([restaurantId, txnDate])
  @@index([restaurantId, sectionId])
  @@unique([restaurantId, id])
}

// ---------------------------------------------------------------------------
// Daily counters — sequential KOT & transaction numbers, reset per day (IST)
// ---------------------------------------------------------------------------
model DailyCounter {
  id           String   @id @default(cuid())
  restaurantId String
  counterDate  String // "YYYY-MM-DD" IST
  kotCount     Int      @default(0)
  billCount    Int      @default(0)
  txnCount     Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@unique([restaurantId, counterDate])
  @@index([restaurantId, counterDate])
}

// ---------------------------------------------------------------------------
// Processed Request IDs — idempotency tracking for offline sync replay
// Used by /settle and /print-bill to prevent duplicate counter increments
// when the same requestId is replayed during bulk sync.
// Pruned nightly: rows older than 7 days are deleted.
// ---------------------------------------------------------------------------
model ProcessedRequest {
  id           String   @id @default(cuid())
  requestId    String
  actionType   String   // "settle" | "print-bill" | "cancel-items" | "transfer-items"
  orderId      String?
  restaurantId String
  deviceId     String?  // originating tablet/phone for multi-device offline attribution
  result       Json?    // cached response body for replay (e.g. { txnNumber, billNumber })
  createdAt    DateTime @default(now())

  @@unique([requestId, actionType, restaurantId])
  @@index([restaurantId, createdAt])
  @@index([deviceId, restaurantId])
}

// ---------------------------------------------------------------------------
// Captain Assignments — revenue targets and discount limits per captain
// ---------------------------------------------------------------------------
model CaptainAssignment {
  id            String   @id @default(cuid())
  restaurantId  String
  captainId     String
  revenueTarget Decimal  @db.Decimal(10, 2)
  discountLimit Decimal  @db.Decimal(10, 2)
  assignedAt    DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@unique([restaurantId, captainId])
  @@index([restaurantId])
  @@index([captainId])
}

// ==========================================
// Bar Inventory Management Models
// ==========================================

model InventoryItem {
  id            String    @id @default(cuid())
  menuItemId    String    @unique
  menuItem      MenuItem  @relation(fields: [menuItemId], references: [id], onDelete: Cascade)
  restaurantId  String
  unitOfMeasure String // "ml", "bottle", "liter"
  bottleSize    Int // Size in ML (750 for spirits, 650 for beer)
  openingStock  Decimal   @db.Decimal(10, 2)
  currentStock  Decimal   @db.Decimal(10, 2)
  reorderLevel  Decimal   @db.Decimal(10, 2)
  costPerBottle Decimal?  @db.Decimal(10, 2)
  lastRestocked DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  transactions   InventoryTransaction[]
  dailySnapshots DailyInventorySnapshot[]

  @@index([restaurantId])
  @@index([menuItemId])
  @@index([currentStock])
  @@unique([restaurantId, id])
  @@map("inventory_items")
}

model InventoryTransaction {
  id              String        @id @default(cuid())
  restaurantId    String
  itemId          String
  item            InventoryItem @relation(fields: [itemId], references: [id], onDelete: Cascade)
  orderId         String?
  type            String // "PURCHASE", "SALE", "WASTAGE", "ADJUSTMENT"
  quantityChange  Decimal       @db.Decimal(10, 2) // Positive for add, negative for deduct
  stockBefore     Decimal       @db.Decimal(10, 2)
  stockAfter      Decimal       @db.Decimal(10, 2)
  notes           String?       @db.Text
  createdBy       String?
  transactionDate DateTime      @default(now())

  @@index([restaurantId, transactionDate])
  @@index([itemId])
  @@index([orderId])
  @@index([type])
  @@unique([restaurantId, id])
  @@map("inventory_transactions")
}

model DailyInventorySnapshot {
  id           String        @id @default(cuid())
  restaurantId String
  snapshotDate String // "YYYY-MM-DD" format
  itemId       String
  item         InventoryItem @relation(fields: [itemId], references: [id], onDelete: Cascade)
  itemName     String
  openingStock Decimal       @db.Decimal(10, 2)
  purchased    Decimal       @db.Decimal(10, 2)
  sold         Decimal       @db.Decimal(10, 2)
  wastage      Decimal       @db.Decimal(10, 2)
  adjusted     Decimal       @db.Decimal(10, 2)
  closingStock Decimal       @db.Decimal(10, 2)
  createdAt    DateTime      @default(now())

  @@unique([restaurantId, snapshotDate, itemId])
  @@index([restaurantId, snapshotDate])
  @@unique([restaurantId, id])
  @@map("daily_inventory_snapshots")
}

// ---------------------------------------------------------------------------
// Venue Pricing — per-venue override prices for shared menu items
// ---------------------------------------------------------------------------
// DEPRECATED: Use PriceProfile + PriceProfileItem for new tenants.
// VenuePrice rows are still read for legacy tenants (venueId as raw string).
// Migration: Phase 3 will backfill existing VenuePrice rows into PriceProfile.
model VenuePrice {
  id           String   @id @default(cuid())
  venueId      String   // e.g. "venue-conference1", "venue-pdr", "venue-rooms", "venue-parcel"
  menuItemId   String
  menuItem     MenuItem @relation(fields: [menuItemId], references: [id], onDelete: Cascade)
  restaurantId String
  restaurant   Outlet     @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  price        Decimal  @db.Decimal(10, 2)
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@unique([venueId, menuItemId])
  @@index([venueId])
  @@index([menuItemId])
  @@index([restaurantId])
  @@unique([restaurantId, id])
}

// ---------------------------------------------------------------------------
// PrintQueue — persistent print job buffer for reconnect recovery
// ---------------------------------------------------------------------------
model PrintQueue {
  id           String   @id @default(cuid())
  restaurantId String
  eventId      String   @unique
  payload      Json
  status       String   @default("PENDING")
  createdAt    DateTime @default(now())
  printedAt    DateTime?

  @@index([restaurantId, status])
  @@index([createdAt])
}

// ==========================================
// Payroll Management Models
// ==========================================

model Employee {
  id             String          @id @default(cuid())
  restaurantId   String
  name           String
  age            Int?
  role           String?
  baseSalary     Decimal         @db.Decimal(10, 2)
  joinDate       DateTime        @default(now())
  isActive       Boolean         @default(true)
  idempotencyKey String?
  payrolls       PayrollRecord[] @relation("PayrollEmployee")
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  @@index([restaurantId])
  @@index([idempotencyKey, restaurantId])
}

model PayrollRecord {
  id            String   @id @default(cuid())
  restaurantId  String
  employeeId    String
  employee      Employee @relation("PayrollEmployee", fields: [employeeId], references: [id], onDelete: Cascade)
  monthYear     String
  baseSalary    Decimal  @db.Decimal(10, 2)
  absentDays    Int      @default(0)
  advanceAmount Decimal  @default(0) @db.Decimal(10, 2)
  otDays        Int      @default(0)
  otAmount      Decimal  @default(0) @db.Decimal(10, 2)
  netPayable    Decimal  @db.Decimal(10, 2)
  paidAmount    Decimal  @default(0) @db.Decimal(10, 2)
  status        String   @default("PENDING")
  notes         String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@unique([employeeId, monthYear])
  @@index([restaurantId, monthYear])
}

// ==========================================
// Kitchen Inventory Management Models
// ==========================================

model KitchenInventoryItem {
  id            String            @id @default(cuid())
  restaurantId  String
  name          String
  unit          String
  currentStock  Decimal           @db.Decimal(10, 2)
  reorderLevel  Decimal           @default(0) @db.Decimal(10, 2)
  recipes       MenuItemRecipe[]
  dailyEntries  InventoryDailyEntry[]
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt

  @@unique([restaurantId, name])
  @@index([restaurantId])
}

model MenuItemRecipe {
  id            String              @id @default(cuid())
  menuItemId    String
  menuItem      MenuItem            @relation(fields: [menuItemId], references: [id], onDelete: Cascade)
  ingredientId  String
  ingredient    KitchenInventoryItem @relation(fields: [ingredientId], references: [id], onDelete: Cascade)
  quantity      Decimal             @db.Decimal(10, 3)
  restaurantId  String

  @@unique([menuItemId, ingredientId])
  @@index([restaurantId])
}

model InventoryDailyEntry {
  id            String              @id @default(cuid())
  restaurantId  String
  entryDate     String
  itemId        String
  item          KitchenInventoryItem @relation(fields: [itemId], references: [id], onDelete: Cascade)
  openingStock  Decimal             @db.Decimal(10, 2)
  addedStock    Decimal             @default(0) @db.Decimal(10, 2)
  consumedStock Decimal             @default(0) @db.Decimal(10, 2)
  closingStock  Decimal             @db.Decimal(10, 2)

  @@unique([restaurantId, itemId, entryDate])
  @@index([restaurantId, entryDate])
}

model AuditLog {
  id           String   @id @default(cuid())
  userId       String?
  restaurantId String?
  action       String
  entityType   String
  entityId     String?
  metadata     Json?
  createdAt    DateTime @default(now())

  @@index([restaurantId, createdAt])
  @@index([userId])
  @@index([entityType, entityId])
}

