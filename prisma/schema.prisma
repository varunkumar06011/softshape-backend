generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// TIP: Append ?connection_limit=20&pool_timeout=30 to DATABASE_URL env var
//      (Prisma reads pool settings from the connection-string query params.)

// ---------------------------------------------------------------------------
// Restaurant — multi-tenancy root & receipt generation
// ---------------------------------------------------------------------------
model Restaurant {
  id        String   @id @default(cuid())
  name      String
  address   String?
  phone     String?
  email     String?
  gstin     String?
  logoUrl   String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ---------------------------------------------------------------------------
// Menu
// ---------------------------------------------------------------------------
model Category {
  id            String     @id @default(uuid())
  name          String
  printerTarget String?    // "KOT_PRINTER" | "BAR_PRINTER" | null (falls back to category-name heuristic)
  sortOrder     Int        @default(0)
  isActive      Boolean    @default(true)
  restaurantId  String
  items         MenuItem[]
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt

  @@index([restaurantId])
  @@index([restaurantId, isActive, sortOrder])
}

model MenuItem {
  id            String            @id @default(uuid())
  name          String
  description   String?
  imageUrl      String?
  basePrice     Decimal           @default(0) @db.Decimal(10, 2)
  isVeg         Boolean           @default(true)
  isAvailable   Boolean           @default(true)
  isDeleted     Boolean           @default(false)
  deletedAt     DateTime?
  menuType      MenuType          @default(FOOD)
  sortOrder     Int               @default(0)
  unit          String?           @db.VarChar(20)
  categoryId    String
  category      Category          @relation(fields: [categoryId], references: [id])
  restaurantId  String
  variants      MenuItemVariant[]
  addons        MenuItemAddon[]
  orderItems    OrderItem[]
  inventoryItem InventoryItem?
  venuePrices   VenuePrice[]
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt

  @@index([categoryId])
  @@index([restaurantId])
  @@index([restaurantId, isAvailable, isDeleted])
}

model MenuItemVariant {
  id          String   @id @default(uuid())
  name        String
  price       Decimal  @db.Decimal(10, 2)
  isDefault   Boolean  @default(false)
  isAvailable Boolean  @default(true)
  menuItemId  String
  menuItem    MenuItem @relation(fields: [menuItemId], references: [id], onDelete: Cascade)

  @@index([menuItemId])
}

model MenuItemAddon {
  id          String   @id @default(uuid())
  name        String
  price       Decimal  @db.Decimal(10, 2)
  isAvailable Boolean  @default(true)
  menuItemId  String
  menuItem    MenuItem @relation(fields: [menuItemId], references: [id], onDelete: Cascade)

  @@index([menuItemId])
}

enum MenuType {
  FOOD
  LIQUOR
}

// ---------------------------------------------------------------------------
// Floor plan
// ---------------------------------------------------------------------------
model Section {
  id           String   @id @default(cuid())
  name         String
  restaurantId String
  tables       Table[]
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Table {
  id               String      @id @default(cuid())
  number           Int
  capacity         Int         @default(4)
  status           TableStatus @default(AVAILABLE)
  workflowStatus   String?
  captainId        String?
  guests           Int         @default(0)
  sessionStartedAt DateTime?
  discount         Decimal?    @db.Decimal(5, 2)
  currentBill      Decimal     @default(0) @db.Decimal(10, 2)
  kotHistory       Json        @default("[]")
  sectionId        String
  section          Section     @relation(fields: [sectionId], references: [id])
  restaurantId     String
  sectionTag       String?     // e.g. "venue-bar-parcel", "venue-restaurant-parcel", "venue-bar-conference"
  orders           Order[]
  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt

  @@unique([restaurantId, sectionId, number])
  @@index([restaurantId, status])
}

enum TableStatus {
  AVAILABLE
  OCCUPIED
  BILLING_REQUESTED
  RESERVED
  CLEANING
}

// ---------------------------------------------------------------------------
// Orders
// ---------------------------------------------------------------------------
model Order {
  id                 String        @id @default(cuid())
  tableId            String
  table              Table         @relation(fields: [tableId], references: [id])
  restaurantId       String
  status             OrderStatus   @default(PENDING)
  lastRequestId      String?
  items              OrderItem[]
  transactions       Transaction[]
  totalAmount        Decimal       @default(0) @db.Decimal(10, 2)
  billNumber         String?
  billingRequested   Boolean       @default(false)
  billingRequestedAt DateTime?
  paidAt             DateTime?
  inventoryDeducted  Boolean       @default(false)   // ← ADD THIS LINE
  isDeleted          Boolean       @default(false)
  deletedAt          DateTime?
  createdAt          DateTime      @default(now())
  updatedAt          DateTime      @updatedAt

  @@index([restaurantId, status])
  @@index([tableId, status])
  @@index([restaurantId, isDeleted])
}

enum OrderStatus {
  PENDING
  CONFIRMED
  PREPARING
  READY
  BILLING_REQUESTED
  PAID
  CANCELLED
}

model OrderItem {
  id              String    @id @default(cuid())
  orderId         String
  order           Order     @relation(fields: [orderId], references: [id], onDelete: Cascade)
  menuItemId      String
  menuItem        MenuItem  @relation(fields: [menuItemId], references: [id])
  name            String
  price           Decimal   @db.Decimal(10, 2)
  quantity        Int
  notes           String?
  menuType        MenuType  @default(FOOD)
  originalQuantity Int?
  cancelledQuantity Int      @default(0)
  editedQuantity   Int       @default(0)
  removedFromBill Boolean   @default(false)
  removedBy       String?
  removedAt       DateTime?
  addedByCashier  Boolean   @default(false)

  @@index([orderId])
  @@index([menuItemId])
}

// ---------------------------------------------------------------------------
// Billing
// ---------------------------------------------------------------------------
model Transaction {
  id           String   @id @default(cuid())
  restaurantId String
  orderId      String?  @unique // one payment record per order; null rows are exempt (PostgreSQL allows multiple NULLs)
  order        Order?   @relation(fields: [orderId], references: [id], onDelete: SetNull)
  tableNumber  Int?
  captainId    String?
  amount       Decimal  @db.Decimal(10, 2)
  method       String // CASH | CARD | UPI | SPLIT
  itemCount    Int      @default(0)
  items        Json     @default("[]")
  subtotal        Decimal?  @db.Decimal(10, 2)
  discountPercent Decimal?  @db.Decimal(5, 2)
  discountAmount  Decimal?  @db.Decimal(10, 2)
  cgst            Decimal?  @db.Decimal(10, 2)
  sgst            Decimal?  @db.Decimal(10, 2)
  grandTotal      Decimal?  @db.Decimal(10, 2)
  txnNumber    Int      @default(0) // daily sequential: 1, 2, 3…
  txnDate      String   @default("") // YYYY-MM-DD in IST — for daily reset
  billNumber   String?  // copied from Order.billNumber at settlement / print-bill
  tableLabel   String?  // extra table display name e.g. "B1-X"; null for regular tables
  paidAt       DateTime @default(now())
  createdAt    DateTime @default(now())

  @@index([restaurantId])
  @@index([restaurantId, paidAt(sort: Desc)])
  @@index([restaurantId, txnDate])
}

// ---------------------------------------------------------------------------
// Daily counters — sequential KOT & transaction numbers, reset per day (IST)
// ---------------------------------------------------------------------------
model DailyCounter {
  id           String   @id @default(cuid())
  restaurantId String
  counterDate  String // "YYYY-MM-DD" IST
  kotCount     Int      @default(0)
  billCount    Int      @default(0)
  txnCount     Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@unique([restaurantId, counterDate])
  @@index([restaurantId, counterDate])
}

// ---------------------------------------------------------------------------
// Captain Assignments — revenue targets and discount limits per captain
// ---------------------------------------------------------------------------
model CaptainAssignment {
  id            String   @id @default(cuid())
  restaurantId  String
  captainId     String
  revenueTarget Decimal  @db.Decimal(10, 2)
  discountLimit Decimal  @db.Decimal(10, 2)
  assignedAt    DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@unique([restaurantId, captainId])
  @@index([restaurantId])
  @@index([captainId])
}

// ---------------------------------------------------------------------------
// Captain Targets — simplified assignment model used by the new target service
// ---------------------------------------------------------------------------
model CaptainTarget {
  id            String   @id @default(cuid())
  restaurantId  String
  captainId     String
  revenueTarget Decimal  @db.Decimal(10, 2)
  discountLimit Decimal  @db.Decimal(10, 2)
  assignedAt    DateTime @default(now())

  @@unique([restaurantId, captainId])
}

// ==========================================
// Bar Inventory Management Models
// ==========================================

model InventoryItem {
  id            String    @id @default(cuid())
  menuItemId    String    @unique
  menuItem      MenuItem  @relation(fields: [menuItemId], references: [id], onDelete: Cascade)
  restaurantId  String
  unitOfMeasure String // "ml", "bottle", "liter"
  bottleSize    Int // Size in ML (750 for spirits, 650 for beer)
  openingStock  Decimal   @db.Decimal(10, 2)
  currentStock  Decimal   @db.Decimal(10, 2)
  reorderLevel  Decimal   @db.Decimal(10, 2)
  costPerBottle Decimal?  @db.Decimal(10, 2)
  lastRestocked DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  transactions   InventoryTransaction[]
  dailySnapshots DailyInventorySnapshot[]

  @@index([restaurantId])
  @@index([menuItemId])
  @@index([currentStock])
  @@map("inventory_items")
}

model InventoryTransaction {
  id              String        @id @default(cuid())
  restaurantId    String
  itemId          String
  item            InventoryItem @relation(fields: [itemId], references: [id], onDelete: Cascade)
  orderId         String?
  type            String // "PURCHASE", "SALE", "WASTAGE", "ADJUSTMENT"
  quantityChange  Decimal       @db.Decimal(10, 2) // Positive for add, negative for deduct
  stockBefore     Decimal       @db.Decimal(10, 2)
  stockAfter      Decimal       @db.Decimal(10, 2)
  notes           String?       @db.Text
  createdBy       String?
  transactionDate DateTime      @default(now())

  @@index([restaurantId, transactionDate])
  @@index([itemId])
  @@index([orderId])
  @@index([type])
  @@map("inventory_transactions")
}

model DailyInventorySnapshot {
  id           String        @id @default(cuid())
  restaurantId String
  snapshotDate String // "YYYY-MM-DD" format
  itemId       String
  item         InventoryItem @relation(fields: [itemId], references: [id], onDelete: Cascade)
  itemName     String
  openingStock Decimal       @db.Decimal(10, 2)
  purchased    Decimal       @db.Decimal(10, 2)
  sold         Decimal       @db.Decimal(10, 2)
  wastage      Decimal       @db.Decimal(10, 2)
  adjusted     Decimal       @db.Decimal(10, 2)
  closingStock Decimal       @db.Decimal(10, 2)
  createdAt    DateTime      @default(now())

  @@unique([restaurantId, snapshotDate, itemId])
  @@index([restaurantId, snapshotDate])
  @@map("daily_inventory_snapshots")
}

// ---------------------------------------------------------------------------
// Venue Pricing — per-venue override prices for shared menu items
// ---------------------------------------------------------------------------
model VenuePrice {
  id         String   @id @default(cuid())
  venueId    String   // e.g. "venue-conference1", "venue-pdr", "venue-rooms", "venue-parcel"
  menuItemId String
  menuItem   MenuItem @relation(fields: [menuItemId], references: [id], onDelete: Cascade)
  price      Decimal  @db.Decimal(10, 2)
  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([venueId, menuItemId])
  @@index([venueId])
  @@index([menuItemId])
}

