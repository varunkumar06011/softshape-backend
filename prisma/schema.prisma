generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Category {
  id           String     @id @default(uuid())
  name         String
  sortOrder    Int        @default(0)
  isActive     Boolean    @default(true)
  restaurantId String
  items        MenuItem[]
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
}

model MenuItem {
  id           String            @id @default(uuid())
  name         String
  description  String?
  imageUrl     String?
  isVeg        Boolean           @default(true)
  isAvailable  Boolean           @default(true)
  menuType     MenuType          @default(FOOD)
  sortOrder    Int               @default(0)
  categoryId   String
  category     Category          @relation(fields: [categoryId], references: [id])
  restaurantId String
  variants     MenuItemVariant[]
  addons       MenuItemAddon[]
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt
}

model MenuItemVariant {
  id         String   @id @default(uuid())
  name       String
  price      Float
  isDefault  Boolean  @default(false)
  menuItemId String
  menuItem   MenuItem @relation(fields: [menuItemId], references: [id])
}

model MenuItemAddon {
  id          String   @id @default(uuid())
  name        String
  price       Float
  isAvailable Boolean  @default(true)
  menuItemId  String
  menuItem    MenuItem @relation(fields: [menuItemId], references: [id])
}

model Section {
  id           String   @id @default(cuid())
  name         String
  restaurantId String
  tables       Table[]
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Table {
  id           String      @id @default(cuid())
  number       Int
  capacity     Int         @default(4)
  status       TableStatus @default(AVAILABLE)
  workflowStatus String?
  captainId    String?
  guests       Int         @default(0)
  sessionStartedAt String?
  currentBill  Float       @default(0)
  kotHistory   Json        @default("[]")
  sectionId    String
  section      Section     @relation(fields: [sectionId], references: [id])
  restaurantId String
  orders       Order[]
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  @@unique([restaurantId, sectionId, number])
  @@index([restaurantId, status])
}

enum TableStatus {
  AVAILABLE
  OCCUPIED
  BILLING_REQUESTED
  RESERVED
  CLEANING
}

model Order {
  id                 String      @id @default(cuid())
  tableId            String
  table              Table       @relation(fields: [tableId], references: [id])
  restaurantId       String
  status             OrderStatus @default(PENDING)
  items              OrderItem[]
  totalAmount        Float       @default(0)
  billingRequested   Boolean     @default(false)
  billingRequestedAt DateTime?
  createdAt          DateTime    @default(now())
  updatedAt          DateTime    @updatedAt

  @@index([restaurantId, status])
  @@index([tableId, status])
}

enum OrderStatus {
  PENDING
  CONFIRMED
  PREPARING
  READY
  BILLING_REQUESTED
  PAID
  CANCELLED
}

model OrderItem {
  id         String @id @default(cuid())
  orderId    String
  order      Order  @relation(fields: [orderId], references: [id], onDelete: Cascade)
  menuItemId String
  name       String
  price      Float
  quantity   Int
  notes      String?
}

model Transaction {
  id           String   @id @default(cuid())
  restaurantId String
  orderId      String?
  tableNumber  Int?
  captainId    String?
  amount       Float
  method       String   // CASH | CARD | UPI | SPLIT
  itemCount    Int      @default(0)
  items        Json     @default("[]")
  paidAt       DateTime @default(now())
  createdAt    DateTime @default(now())

  @@index([restaurantId])
  @@index([restaurantId, paidAt])
}

enum MenuType {
  FOOD
  LIQUOR
}
